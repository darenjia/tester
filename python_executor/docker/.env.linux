# Python执行器环境变量配置
# Linux容器部署（开发/测试）

# ===== 执行器配置 =====
EXECUTOR_ID=executor-linux-01
EXECUTOR_NAME=Linux执行器
VERSION=v1.0.0-linux

# ===== 日志配置 =====
LOG_LEVEL=INFO
DEBUG=false

# ===== 平台配置 =====
PLATFORM_HOST=host.docker.internal
PLATFORM_PORT=8080

# ===== 路径配置 =====
CONFIG_DIR=./config
WORK_DIR=./work

# ===== 端口配置 =====
API_PORT=5000
WS_PORT=5001

# ===== 测试工具配置 =====
CANOE_ENABLED=false
TSMASTER_ENABLED=false

# ===== 构建参数 =====
BUILD_DATE=2026-02-27
