# Python执行器环境变量配置
# Windows容器部署

# ===== 执行器配置 =====
EXECUTOR_ID=executor-01
EXECUTOR_NAME=执行器1
VERSION=v1.0.0

# ===== 日志配置 =====
LOG_LEVEL=INFO
DEBUG=false

# ===== 平台配置 =====
PLATFORM_HOST=platform-api
PLATFORM_PORT=8080

# ===== 路径配置 =====
CONFIG_DIR=./config
WORK_DIR=./work

# ===== 端口配置 =====
API_PORT=5000
WS_PORT=5001

# ===== 资源限制 =====
CPU_LIMIT=4
MEMORY_LIMIT=8G
CPU_RESERVE=2
MEMORY_RESERVE=4G

# ===== 测试工具配置 =====
CANOE_ENABLED=true
CANOE_PATH=C:/Program Files/CANoe
TSMASTER_ENABLED=true
TSMASTER_PATH=C:/Program Files/TSMaster

# ===== 构建参数 =====
BUILD_DATE=2026-02-27
