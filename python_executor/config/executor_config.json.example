# 示例配置文件
# 将此文件复制为 executor_config.json 并进行自定义配置

{
    "websocket": {
        "host": "0.0.0.0",
        "port": 8180,
        "heartbeat_interval": 30,
        "reconnect_interval": 5,
        "max_reconnect_attempts": 3
    },
    "logging": {
        "level": "INFO",
        "file": "logs/executor.log",
        "max_size": 10485760,
        "backup_count": 5
    },
    "task": {
        "timeout": 3600,
        "check_interval": 1,
        "max_concurrent": 1
    },
    "canoe": {
        "timeout": 30,
        "config_timeout": 60
    },
    "tsmaster": {
        "timeout": 30,
        "config_timeout": 60
    },
    "result": {
        "batch_size": 10,
        "upload_interval": 5
    }
}