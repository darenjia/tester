void ANetT_DUTDatabase_CycleID(char DUTName1[],byte DLC[],dword ID[],int& ID_N,int signal_N[],dword cycletime[],byte check_method[][],byte startbit[][],byte length[][],byte ini_value[][])//数据库信息提取完全版
{
   int i,j,k,m=0;
   char DUTName[100];
  
  
  
  
  substr_cpy(DUTName,DUTName1,0,-1,elcount(DUTName));
 
  for(i=0;i<T_Clsts[0].T_DUTnumber;i++)
   {
      if(strncmp(DUTName,T_Clsts[0].T_DUT[i].name,100)==0)
      {
        break;
      }

   }
   m=0;
  
 for(j=0;j<T_Clsts[0].T_DUT[i].Tmsgnumber;j++)
   {
      if(T_Clsts[0].T_DUT[i].T_msg[j].method==0)
      { 
        DLC[m]=T_Clsts[0].T_DUT[i].T_msg[j].DLC;//获取DLC
        cycletime[m]=T_Clsts[0].T_DUT[i].T_msg[j].cycletime;//获取周期
        ID[m]=T_Clsts[0].T_DUT[i].T_msg[j].ID;//获取ID
         for(k=0;k<T_Clsts[0].T_DUT[i].T_msg[j].signalnumber;k++)
          {
            startbit[m][k]=T_Clsts[0].T_DUT[i].T_msg[j].Sub_signal[k].startbit;//
            length[m][k]=T_Clsts[0].T_DUT[i].T_msg[j].Sub_signal[k].length;//
            //write("length[%d][%d]=======%d",m,k,length[j][k]);
            ini_value[m][k]=T_Clsts[0].T_DUT[i].T_msg[j].Sub_signal[k].ini_value;//
            check_method[m][k]=T_Clsts[0].T_DUT[i].T_msg[j].Sub_signal[k].rout_method;//rolling counter 和checksum 用  
          } 
        signal_N[m]=k;
        m++;
      }
   }
  
  ID_N=m;
}

