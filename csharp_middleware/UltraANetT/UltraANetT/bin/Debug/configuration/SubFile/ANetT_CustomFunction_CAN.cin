}

void Wrost_Result_Find(int selected,float Data[],int mod,float& average)//平均值
{
  int   i;
  float Average=0;

  if(mod==3)//平均值
  {

    for(i=0;i<abs(global_array_selected[selected-1]);i++)
    {
      Average=Data[i]+Average;
      average=Average;

    }
  }
  
}

