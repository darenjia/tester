  float wrostK=0;
  float wrostData=0;
 
  if(mod==2)//离标准最远
  {
    wrostK=abs(Data[0]-Standard);
    wrostData=Data[0];
    WorstNum=0;
    for(i=0;i<num;i++)
    {
       if(wrostK<abs(Data[i]-Standard))
       {
        wrostK=abs(Data[i]-Standard);
        wrostData=Data[i];
        WorstNum=i;
       } 
    }
  }
}

void Wrost_Result_Find(int selected,float Data[],int mod,int& WorstNum)//最差值
{
  int i;
  float wrost;
  
  wrost=Data[0];
  WorstNum=0;
  if(mod==0)//最小值
  {
    WorstNum=0;
    for(i=0;i<abs(global_array_selected[selected-1]);i++)
    {
     if(wrost>Data[i])
     {
      wrost=Data[i];
      WorstNum=i;
     }
    }
  }
  else if(mod==1)//最大值
  {
    WorstNum=0;
    for(i=0;i<abs(global_array_selected[selected-1]);i++)
    {
     if(wrost<Data[i])
     {
      wrost=Data[i];
      WorstNum=i;
     }
    }
  }
}

