void ANetT_DUTDatabase_ID(char DUTName1[],byte DLC[],dword ID[],int& ID_N,int& signal_N,dword cycletime[],byte method[],byte startbit[][],byte length[][],byte ini_value[][])//数据库信息提取完全版
{
   int i,j,k,m=0;
  char DUTName[1000];
 substr_cpy(DUTName,DUTName1,0,-1,elcount(DUTName));
 
 for(i=0;i<T_Clsts[0].T_DUTnumber;i++)
  {
    if(strncmp(DUTName,T_Clsts[0].T_DUT[i].name,100)==0)
    {
      break;
    }
  }
   m=0;
 for(j=0;j<T_Clsts[0].T_DUT[i].Tmsgnumber;j++)
  {
    if(T_Clsts[0].T_DUT[i].T_msg[j].method==0)
   {
      DLC[m]=T_Clsts[0].T_DUT[i].T_msg[j].DLC;//获取DLC
      cycletime[m]=T_Clsts[0].T_DUT[i].T_msg[j].cycletime;//获取周期
      ID[m]=T_Clsts[0].T_DUT[i].T_msg[j].ID;//获取ID
      method[m]=T_Clsts[0].T_DUT[i].T_msg[j].method;//获取ID发送方式
     for(k=0;k<T_Clsts[0].T_DUT[i].T_msg[j].signalnumber;k++)
     {
      startbit[10][k]=T_Clsts[0].T_DUT[i].T_msg[j].Sub_signal[k].startbit;//
      length[10][k]=T_Clsts[0].T_DUT[i].T_msg[j].Sub_signal[k].length;//
      ini_value[10][k]=T_Clsts[0].T_DUT[i].T_msg[j].Sub_signal[k].ini_value;//
     } 
      m++;
   }

  }
  ID_N=m;
  signal_N=k;
}



void ANetT_DUTDatabase_ID(char DUTName1[],dword ID[],int& ID_N,dword cycletime[],byte DLC[])//数据库信息提取ID信息
{
  int i,j,m=0;
  char DUTName[1000];
  
  substr_cpy(DUTName,DUTName1,0,-1,elcount(DUTName));
 for(i=0;i<T_Clsts[0].T_DUTnumber;i++)
  {
    if(strncmp(DUTName,T_Clsts[0].T_DUT[i].name,100)==0)
    {
      break;
    }
  }
  m=0;
 for(j=0;j<T_Clsts[0].T_DUT[i].Tmsgnumber;j++)
  {
    if(T_Clsts[0].T_DUT[i].T_msg[j].method==0)
    {
      DLC[m]=T_Clsts[0].T_DUT[i].T_msg[j].DLC;//获取报文长度
      cycletime[m]=T_Clsts[0].T_DUT[i].T_msg[j].cycletime;//获取周期
      ID[m]=T_Clsts[0].T_DUT[i].T_msg[j].ID;//获取ID 
      m++;

    }

  }
  ID_N=m;
  
}

