void ANetT_cycle_frame(char path[],dword ID[],int ID_N,float& Time)//030
{
   int i=0;
   char s1[1000];
   char s2[1000];
  
  substr_cpy(s1," ",0,-1,7);substr_cpy(s2," ",0,-1,7);
  
  
  
   for(i;i<ID_N;i++)
   {
     strncat(s2,"0x",100);
     ltoa(ID[i],s1,16);
     strncat(s2,s1,100);
   }
   substr_cpy(CL_frame_ID,"007",0,-1,7);
   substr_cpy(CL_frame_FC,"030",0,-1,7);
   substr_cpy(CL_frame_DL,"2",0,-1,7);
   substr_cpy(CL_frame_DATA[0],path,0,-1,5000);
   substr_cpy(CL_frame_DATA[1],s2,0,-1,5000);
  
   substr_cpy(CL_frame_ACK,"001",0,-1,7);
   CL_frame_build();
   CL_trans_frame();
   strtod(LC_frame_DATA[0],Time);
}

void ANetT_NetLoc_awaketime(char path[],dword awakeID,dword respondID,float& Time,float& Firstbyte,float& FirstID,float& FirstIsNetM)//031
{
   int i=0;
   char s1[100];
   char s2[100];
   char s3[100];
   char s4[100];
  
  substr_cpy(s1," ",0,-1,7);substr_cpy(s2," ",0,-1,7);substr_cpy(s3," ",0,-1,7);
  substr_cpy(s4," ",0,-1,7);  
  
   strncat(s1,"0x",100);
   ltoa(awakeID,s3,16);
   strncat(s1,s3,100);
   strncat(s2,"0x",100);
   ltoa(respondID,s4,16);
   strncat(s2,s4,100);

   substr_cpy(CL_frame_ID,"007",0,-1,7);
   substr_cpy(CL_frame_FC,"031",0,-1,7);
   substr_cpy(CL_frame_DL,"3",0,-1,7);
   substr_cpy(CL_frame_DATA[0],path,0,-1,5000);
   substr_cpy(CL_frame_DATA[1],s1,0,-1,5000);
   substr_cpy(CL_frame_DATA[2],s2,0,-1,5000);
  
   substr_cpy(CL_frame_ACK,"001",0,-1,7);
   CL_frame_build();
   CL_trans_frame();
   strtod(LC_frame_DATA[0],Time);
   strtod(LC_frame_DATA[1],Firstbyte);
   strtod(LC_frame_DATA[2],FirstID);
   strtod(LC_frame_DATA[3],FirstIsNetM);
}

