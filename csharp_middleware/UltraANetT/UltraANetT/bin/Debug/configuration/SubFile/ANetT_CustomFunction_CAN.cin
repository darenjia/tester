//********************************数据处理函数****************************************//
variables
{
   struct CATARC_DUTDatabase_Messgae
    {
      byte DLC[100];//信号起始位
      dword ID[100];//信号长度
      byte cycletime[10];//信号默认值
      byte method[100];//信号十进制最大值
      byte startbit[10][100];//信号起始位
      byte length[10][100];//信号长度
      byte ini_value[10][100];//信号默认值
    };
}

void ANetT_CANHrecessiveV(char path[],float& V)
{
   int a=0;
   char string0[100];
  
   substr_cpy(CL_frame_ID,"007",0,-1,7);
   substr_cpy(CL_frame_FC,"001",0,-1,7);
   substr_cpy(CL_frame_DL,"1",0,-1,7);
   substr_cpy(CL_frame_DATA[0],path,0,-1,5000);

   
   substr_cpy(CL_frame_ACK,"001",0,-1,7);
   CL_frame_build();
   CL_trans_frame();
   strtod(LC_frame_DATA[0],V);
   putValue(envir_labview_display,"ANetT_CANHdominantV"); 
}

