    strncat(k,"(",5000);
    strncat(k,DUTname,5000);
    strncat(k,")",5000);
  strncat(k,".",5000);
  strncat(k,file_format,5000);
  substr_cpy(return_filname1,k,0,-1,5000);
}

void Wrost_Result_Find(int selected,float Data[],int mod,float Standard,int& WorstNum)//最差值float
{
  int   i=0;
  float mid=0;
  float wrostK=0;
  float wrostData=0;
 
  if(mod==2)//离标准最远
  {
    wrostK=abs(Data[0]-Standard);
    wrostData=Data[0];
    WorstNum=0;
    for(i=0;i<abs(global_array_selected[selected-1]);i++)
    {
       if(wrostK<abs(Data[i]-Standard))
       {
        wrostK=abs(Data[i]-Standard);
        wrostData=Data[i];
        write("D===========%f",Data[i]);
        WorstNum=i;
       } 
    }
   
  }
}

void Wrost_Result_Num_Find(int num,float Data[],int mod,float Standard,int& WorstNum)//最差值float
{
  int   i=0;
