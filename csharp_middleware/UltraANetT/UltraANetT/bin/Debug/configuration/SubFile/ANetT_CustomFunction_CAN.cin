void ANetT_Tbit(char path1[],char path2[],float Timebase,int& result,float Xa[],float Xb[])//041 位精度测试
{
   int a=0;
   char string0[10],string1[10],string2[10];
  
   _gcvt(Timebase,3,string0);
 
   substr_cpy(CL_frame_ID,"007",0,-1,7);
   substr_cpy(CL_frame_FC,"041",0,-1,7);
   substr_cpy(CL_frame_DL,"3",0,-1,7);
   substr_cpy(CL_frame_DATA[0],path1,0,-1,5000);
   substr_cpy(CL_frame_DATA[1],path2,0,-1,5000);
   substr_cpy(CL_frame_DATA[2],string0,0,-1,5000);

  
  
   substr_cpy(CL_frame_ACK,"001",0,-1,7);
   CL_frame_build();
   CL_trans_frame();
   substr_cpy(string1,LC_frame_DATA[0],0,-1,5000);
   for(a=1;a<6;a++)
  {
    substr_cpy(string2,LC_frame_DATA[a],0,-1,5000);
    Xa[a-1]=atodbl(string2);    
  }
   for(a=6;a<11;a++)
  {
    substr_cpy(string2,LC_frame_DATA[a],0,-1,5000);
    Xb[a-6]=atodbl(string2);    
  }  
   result=atol(string1);
   write("result====%d",result);
   write("Xb0==Xb1==Xb2====%f===%f===%f",Xb[0],Xb[1],Xb[2]);
   write("Xa0==Xa1==Xa2====%f===%f===%f",Xa[0],Xa[1],Xa[2]);
   putValue(envir_labview_display,"ANetT_Tbit"); 
}

