void ANetT_SamplingPoint(dword  SP_Errortime[],int& ContinueErrorFrameNum)//024
{
   int  a,Num;

  ContinueErrorFrameNum=0;
  Num=0;
  
   for(a=0;a<20;a++)
  {
    if( 0<(SP_Errortime[a+1]-SP_Errortime[a]) && (SP_Errortime[a+1]-SP_Errortime[a])<50 ) // 50->500us
      Num++;
    else
      {
        if(ContinueErrorFrameNum < Num)
        {ContinueErrorFrameNum = Num; write("ContinueErrorFrameNum=====%d",ContinueErrorFrameNum);}
        else
          {}
        Num=0;
      } 
  }

  write("ContinueErrorFrameNum222222=====%d",ContinueErrorFrameNum);
}

void ANetT_FaultTime_ms(char path[],int Mode,float Level,float Timebase,float& ResultTime)//025
{
   int a=0;
   char string0[100];
   char s1[100];
   char string1[100];
   char string2[100];
  
   ltoa(Mode,string0,10);
   _gcvt(Level,10,string1);
   _gcvt(Timebase,10,string2);

  
   substr_cpy(CL_frame_ID,"007",0,-1,7);
   substr_cpy(CL_frame_FC,"025",0,-1,7);
   substr_cpy(CL_frame_DL,"4",0,-1,7);
   substr_cpy(CL_frame_DATA[0],path,0,-1,5000);
   substr_cpy(CL_frame_DATA[1],string0,0,-1,5000);
   substr_cpy(CL_frame_DATA[2],string1,0,-1,5000);
   substr_cpy(CL_frame_DATA[3],string2,0,-1,5000);

   substr_cpy(CL_frame_ACK,"001",0,-1,7);
   CL_frame_build();
   CL_trans_frame();
   strtod(LC_frame_DATA[0],ResultTime);
   putValue(envir_labview_display,"ANetT_FaultTime_ms"); 
}

