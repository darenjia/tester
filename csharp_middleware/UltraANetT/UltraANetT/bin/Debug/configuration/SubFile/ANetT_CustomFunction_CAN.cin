void ANetT_DUTDatabase_ID(char DUTName1[],int& signal_N,byte startbit[][],byte length[][],byte ini_value[][])//数据库信息提取signa信息
{
   int i,j,k,m=0;
  char DUTName[1000];
  substr_cpy(DUTName,DUTName1,0,-1,elcount(DUTName));
 for(i=0;i<T_Clsts[0].T_DUTnumber;i++)
  {
    if(strncmp(DUTName,T_Clsts[0].T_DUT[i].name,100)==0)
    {
      break;
    }
  }
 for(j=0;j<T_Clsts[0].T_DUT[i].Tmsgnumber;j++)
  {
    
    for(k=0;k<T_Clsts[0].T_DUT[i].T_msg[j].signalnumber;k++)
    {
      startbit[10][0]=T_Clsts[0].T_DUT[i].T_msg[j].Sub_signal[k].startbit;//
      length[10][k]=T_Clsts[0].T_DUT[i].T_msg[j].Sub_signal[k].length;//
      ini_value[10][k]=T_Clsts[0].T_DUT[i].T_msg[j].Sub_signal[k].ini_value;//
    }
  }
  signal_N=k-1;
  
}

