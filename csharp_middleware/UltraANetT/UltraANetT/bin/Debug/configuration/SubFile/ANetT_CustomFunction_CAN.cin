int Search1DArray(dword array[],dword element)
{
  int  i,Nummax,Num,state;
  int Serial; 

  Nummax=0;
  state=0;

  while(1)
  {
    if(state==1)
    break;
    else
    {
      Nummax=Nummax+100;
      for(i=0;i<Nummax;i++)
      {
        if(array[i]==0)
        { Num=i;state=1;break;}
      }
    }
  }
  if(Num==0)
  Serial=-1;
  else
  Serial=999; 
  
  for(i=0;i<Num;i++)
  {
    if(element==array[i])
    { Serial=i;break;}    
  }
  
  return Serial;
}

void MaxOrMin(int ArraySize,int Data[],int mod,int& WorstNum)//最差值
{
  int i;
  float wrost;
  
  wrost=Data[0];
  WorstNum=0;
  if(mod==0)//最小值
  {
    WorstNum=0;
    for(i=0;i<ArraySize;i++)
    {
     if(wrost>Data[i])
     {
      wrost=Data[i];
      WorstNum=i;
     }
    }
  }
  else if(mod==1)//最大值
  {
    WorstNum=0;
    for(i=0;i<ArraySize;i++)
    {
     if(wrost<Data[i])
     {
      wrost=Data[i];
      WorstNum=i;
     }
    }
  }
}

