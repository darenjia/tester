void LogFileName_times(char return_filname1[],char main_filename1[],char sub_filename1[],char file_format1[])
{
  char x[10];
  char k[500];
  char ss2[100];
  char return_filname[1000];
  char main_filename[1000];
  char sub_filename[1000];
  char file_format[1000];
  
  
  
  substr_cpy(return_filname,return_filname1,0,-1,elcount(return_filname));
  substr_cpy(main_filename,main_filename1,0,-1,elcount(main_filename));
  substr_cpy(sub_filename,sub_filename1,0,-1,elcount(sub_filename));
