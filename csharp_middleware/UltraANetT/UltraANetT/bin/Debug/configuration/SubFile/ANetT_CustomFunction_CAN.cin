void ANetT_setLogFileName(char fileName1[])
{
  int i;
  float mid=0;
  float wrostK=0;
  float wrostData=0;
  char fileName[1000];
  substr_cpy(fileName,fileName1,0,-1,elcount(fileName));
  stopLogging();
  setLogFileName(fileName);
  Testwaitfortimeout(2000);
}

void ANetT_stopLogFileName()
{
  stopLogging();
  setLogFileName("C:\\Users\\C226\\Desktop\\BB22222.asc");
  
  startLogging();
  Testwaitfortimeout(2000);
  stopLogging();
}

void ANetT_ResultDescribe(char Describe1[],float Data1,char AA[])                              //报告描述函数
{
  int  front=-1,i=0;
  char Data_str1[100];
  char frontstr[100];
  char backstr[100];
  char Describe[1000];
  char Variable2[1000];
  
  
  substr_cpy(Describe,Describe1,0,-1,elcount(Describe));
    front=-1;
    _gcvt(Data1,4,Data_str1);
    if(strstr(Data_str1,".")!=-1&&(strstr(Data_str1,".")+1)==strlen(Data_str1))
    {
      substr_cpy(Data_str1,Data_str1,0,strlen(Data_str1)-1,100);
    }
    
    for(i=0;i<50;i++)
    {
       if(strstr(Describe,"%1f")==-1)
      {
        substr_cpy(AA,Describe,0,-1,elcount(Describe));
        break;
      }
       front=strstr(Describe,"%1f"); 
       substr_cpy(Variable2,Describe,0,front,elcount(Describe));
       strncat(Variable2,Data_str1,5000);
       substr_cpy(backstr,Describe,front+3,-1,elcount(Describe));
       strncat(Variable2,backstr,5000);
       substr_cpy(Describe,Variable2,0,-1,elcount(Variable2));
    }
    substr_cpy(AA,Describe,0,-1,elcount(Describe));
}

