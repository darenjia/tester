void DeleteFile(char path[])
{
   substr_cpy(CL_frame_ID,"007",0,-1,7);
   substr_cpy(CL_frame_FC,"201",0,-1,7);
   substr_cpy(CL_frame_DL,"1",0,-1,7);
   substr_cpy(CL_frame_DATA[0],path,0,-1,5000);

  
   substr_cpy(CL_frame_ACK,"001",0,-1,7);
   CL_frame_build();
   CL_trans_frame();
  
}

void DUTIDAcquire(char path[],int& Num,dword ID[])//0202 DUT当前发送ID
{
   int a=0;
   char string0[10],string1[10],string2[50][10];
  
 
   substr_cpy(CL_frame_ID,"007",0,-1,7);
   substr_cpy(CL_frame_FC,"202",0,-1,7);
   substr_cpy(CL_frame_DL,"1",0,-1,7);
   substr_cpy(CL_frame_DATA[0],path,0,-1,5000);
  
   substr_cpy(CL_frame_ACK,"001",0,-1,7);
   CL_frame_build();
   CL_trans_frame();
  
   substr_cpy(string1,LC_frame_DATA[0],0,-1,5000);
   Num=atol(string1);
   for(a=1;a<=Num;a++)
  { 
    substr_cpy(string2[a-1],LC_frame_DATA[a],0,-1,5000); 
    ID[a-1]=atol(string2[a-1]);
    write("ID[a-1]====%d====%x",(a-1),ID[a-1]);
  }

   putValue(envir_labview_display,"DUTIDAcquire"); 
}

