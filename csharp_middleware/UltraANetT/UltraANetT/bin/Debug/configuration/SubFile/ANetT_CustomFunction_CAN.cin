  substr_cpy(k,main_filename,0,-1,5000);
  strncat(k,"\\",5000);
  strncat(k,sub_filename,5000);
  strncat(k,"(",5000);
    _gcvt(time,6,x);
    substr_cpy(ss2,x,strlen(x)-1,1,100);
    if(strncmp(".",ss2,1)==0)
    {
      substr_cpy(ss2,x,0,strlen(x)-1,100);
    }
