qword ANeT_Message_bit_get(qword data,byte StartBit,byte length_data,int Is_Intel)
{
  int i=0,j=0;
  byte out_bit[64];
  byte get_bit[64];
  qword out_k=0;
  qword out_data=0;
  int start_bit;
  
  start_bit=StartBit;
  out_k=data;
  out_data=0;//初始化给初始值不能用
  
  for(i=0;i<64;i++)
  {
    out_bit[i]=0;
    get_bit[i]=0;
  }
  if(Is_Intel==1)
  {
        for(i=0;i<64;i++)
        {
            out_bit[i]=(out_k & 0x01 == 1);
            out_k=out_k>>1;
        }
        for(j=0;j<length_data;j++)
        {
           get_bit[j]=out_bit[start_bit+j];
        }
        for(j=length_data-1;j>=0;j--)
        {
          out_data = out_data<<1;
          out_data = out_data | get_bit[j];
        }
   }
  else
  {
          for(i=0;i<64;i++)
          {
              out_bit[i]=(out_k & 0x01 == 1);
              out_k=out_k>>1;
          }
          for(j=0;j<length_data;j++)
          {
             get_bit[j]=out_bit[start_bit+j];
              if((start_bit+j+1)%8==0)
              {
                start_bit=start_bit-16;
              }
          }
          for(j=length_data-1;j>=0;j--)
          {
            out_data = out_data<<1;
            out_data = out_data | get_bit[j];
          }
  }
  return out_data;
}


void OutMessage(dword ID,int DLC,byte Data[])
{
  message * msg[500];
  int i;
  msg[0].ID = ID;
  msg[0].dlc = DLC;
  for(i=0;i<DLC;i++)
  {
    msg[0].byte(i) = Data[i];
  }
  output(msg[0]);
}

void OutMessage(dword ID,int DLC)
{
  message * msg[500];
  int i;
  msg[0].ID = ID;
  msg[0].dlc = DLC;

  output(msg[0]);
}

void OutMessage(dword ID)
{
  message * msg[500];
  int i;
  msg[0].ID = ID;
  msg[0].dlc = 8;
  for(i=0;i<8;i++)
  {
    msg[0].byte(i) = 0;
  }
  output(msg[0]);
}

void ArrayInital(int array[],int size)

{
  int a;
  a=0;
  do
  {
    array[a]=0;
    a++;
  }while(a<size);
}

