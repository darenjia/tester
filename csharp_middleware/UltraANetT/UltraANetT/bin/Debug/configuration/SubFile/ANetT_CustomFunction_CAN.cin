void ANetT_standard_ID(char path[],dword standardID[],int ID_N,char returnID[],float& record)//033
{
   int i=0;
   int j=0;
   char s1[1000];
   char s2[1000];
  
  substr_cpy(s1," ",0,-1,5000);substr_cpy(s2," ",0,-1,5000);
  
  
   for(j=0;j<ID_N;j++)
   {
     strncat(s1,"0x",1000);
     ltoa(standardID[j],s2,16);
     strncat(s1,s2,1000);
   }
   write("s1==要检测ID===%s",s1);
   substr_cpy(CL_frame_ID,"007",0,-1,7);
   substr_cpy(CL_frame_FC,"033",0,-1,7);
   substr_cpy(CL_frame_DL,"2",0,-1,7);
   substr_cpy(CL_frame_DATA[0],path,0,-1,5000);
   substr_cpy(CL_frame_DATA[1],s1,0,-1,5000);
   substr_cpy(CL_frame_ACK,"001",0,-1,7);
   CL_frame_build();
   CL_trans_frame();
   substr_cpy(returnID,LC_frame_DATA[0],0,-1,5000);
   strtod(LC_frame_DATA[1],record);
}

void ANetT_standard_DLC(char path[],dword standardID[],int ID_N,byte standardDLC[],char returnID[],float& record)//034
{
   int i=0;
   int j=0;
   char s1[1000];
   char s2[1000];
   char s3[1000];
   char s4[1000];
  
   substr_cpy(s1,"",0,-1,5000);
   substr_cpy(s2,"",0,-1,5000);
   substr_cpy(s3,"",0,-1,5000);
   substr_cpy(s4,"",0,-1,5000); 
  
     for(j=0;j<ID_N;j++)
   {
     strncat(s1,"0x",1000);
     ltoa(standardID[j],s2,16);
     strncat(s1,s2,1000);
   }
   write("s1==所有ID==%s",s1);
     for(j=0;j<ID_N;j++)
   {
     ltoa(standardDLC[j],s3,16);
     strncat(s4,s3,1000);
   }
  
   write("s4==所有DLC==%s",s4);
   substr_cpy(CL_frame_ID,"007",0,-1,7);
   substr_cpy(CL_frame_FC,"034",0,-1,7);
   substr_cpy(CL_frame_DL,"3",0,-1,7);
   substr_cpy(CL_frame_DATA[0],path,0,-1,5000);
   substr_cpy(CL_frame_DATA[1],s1,0,-1,5000);// 标准ID  
   substr_cpy(CL_frame_DATA[2],s4,0,-1,5000);// 标准DLC
   substr_cpy(CL_frame_ACK,"001",0,-1,7);
   CL_frame_build();
   CL_trans_frame();
   substr_cpy(returnID,LC_frame_DATA[0],0,-1,5000);
   strtod(LC_frame_DATA[1],record);
}

void ANetT_percycle_frame(char path[],dword standardID[],int ID_N,dword standardcycletime[],char returnID[],float& record)//035
{
   int i=0;
   int j=0;
   char s1[1000];
   char s2[1000];
   char s3[1000];
   char s4[1000];

  substr_cpy(s1," ",0,-1,7);substr_cpy(s2," ",0,-1,7);substr_cpy(s3," ",0,-1,7);
  substr_cpy(s4," ",0,-1,7);

     for(j=0;j<ID_N;j++)
   {
     strncat(s1,"0x",1000);
     ltoa(standardID[j],s2,16);
     strncat(s1,s2,1000);
   }
  write("==所有ID====%s",s1);
  
     for(j=0;j<ID_N;j++)
   {
     ltoa(standardcycletime[j],s3,10);
     strncat(s4,s3,1000);
     strncat(s4,"ms",1000);
   }
  write("=所有周期=====%s",s4);
   substr_cpy(CL_frame_ID,"007",0,-1,7);
