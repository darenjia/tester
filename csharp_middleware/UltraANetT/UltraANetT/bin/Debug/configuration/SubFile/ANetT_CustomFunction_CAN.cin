void ANetT_DUTDatabase_CycleSearch(char DUTName1[],dword DUTID[],int IDNum,dword cycletime[])
{
   int i,j,m=0;
   char DUTName[1000];
  
   substr_cpy(DUTName,DUTName1,0,-1,elcount(DUTName));
    
   for(i=0;i<T_Clsts[0].T_DUTnumber;i++)
    {
      if(strncmp(DUTName,T_Clsts[0].T_DUT[i].name,100)==0)
      {
        break;
      }
    }
    
    for(m=0;m<IDNum;m++)
    {
      write("DUTID[m]===%d=====%x",m,DUTID[m]);
     for(j=0;j<T_Clsts[0].T_DUT[i].Tmsgnumber;j++)
      {
        if(T_Clsts[0].T_DUT[i].T_msg[j].method==0 && T_Clsts[0].T_DUT[i].T_msg[j].ID==DUTID[m])
        {
          cycletime[m]=T_Clsts[0].T_DUT[i].T_msg[j].cycletime;//获取周期
          write("id====cycle====%x,%d",DUTID[m],cycletime[m]);
        }
      } 
    }
}

