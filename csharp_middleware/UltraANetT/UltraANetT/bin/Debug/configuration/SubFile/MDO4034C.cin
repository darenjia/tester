long OSC_Single(long Mode)
{
  char Sbuf[100];
  char Dbuf[100];
  char ModeTemp[10];
  long Re=0;
  
  ltoa(Mode,ModeTemp,10); 
  
  strncpy(Sbuf,"",elCount(Sbuf));
  strncat(Sbuf,"OSC_Single@",elCount(Sbuf));
  strncat(Sbuf,ModeTemp,elCount(Sbuf));
  strncat(Sbuf,"@",elCount(Sbuf));
  
  
  putValue(CAPL_String,Sbuf);
  testWaitForTimeout(1);
  putValue(CAPL_TIME,timeNow());
  while(1)
  {
    if(getValue(StateMachine_TIME)!=State_TIME_)
    {
      getValue(StateMachine_String,State_String_);
      break;
    }
    testWaitForTimeout(1);
  }
  k1=strstr_off(State_String_,0,"@");
  if(k1>0)
  {
    substr_cpy(Dbuf,State_String_,0,k1,elCount(Dbuf));
    Re=atol(Dbuf);
  }
  else Re=-1;
  State_TIME_=getValue(StateMachine_TIME);
  testWaitForTimeout(5000);//防止还没有触发到
  return Re;
}

long OSC_Cursor(long Channel, long Mode, float Xa,float Xb,float Ya,float Yb)
{
  char Sbuf[100];
  char Dbuf[100];
  char ChannelTemp[10];
  char ModeTemp[10];
  char XaTemp[20];
  char XbTemp[20];
  char YaTemp[20];
  char YbTemp[20];  
  long Re=0;
  
  
  
  ltoa(Channel,ChannelTemp,10);
  ltoa(Mode,ModeTemp,10);
  
  snprintf(XaTemp,elCount(XaTemp),"%.15f",Xa);
  snprintf(XbTemp,elCount(XbTemp),"%.15f",Xb);
  snprintf(YaTemp,elCount(YaTemp),"%.15f",Ya);
  snprintf(YbTemp,elCount(YbTemp),"%.15f",Yb);

  strncpy(Sbuf,"",elCount(Sbuf));
  strncat(Sbuf,"OSC_Cursor@",elCount(Sbuf));
  strncat(Sbuf,ChannelTemp,elCount(Sbuf));
  strncat(Sbuf,"@",elCount(Sbuf));
  strncat(Sbuf,ModeTemp,elCount(Sbuf));
  strncat(Sbuf,"@",elCount(Sbuf));
  strncat(Sbuf,XaTemp,elCount(Sbuf));
  strncat(Sbuf,"@",elCount(Sbuf));
  strncat(Sbuf,XbTemp,elCount(Sbuf));
  strncat(Sbuf,"@",elCount(Sbuf));
  strncat(Sbuf,YaTemp,elCount(Sbuf));
  strncat(Sbuf,"@",elCount(Sbuf));  
  strncat(Sbuf,YbTemp,elCount(Sbuf));
  strncat(Sbuf,"@",elCount(Sbuf));  
  
  
  putValue(CAPL_String,Sbuf);
  testWaitForTimeout(1);
  putValue(CAPL_TIME,timeNow());
  while(1)
  {
    if(getValue(StateMachine_TIME)!=State_TIME_)
    {
      getValue(StateMachine_String,State_String_);
      break;
    }
    testWaitForTimeout(1);
  }
  k1=strstr_off(State_String_,0,"@");
  if(k1>0)
  {
    substr_cpy(Dbuf,State_String_,0,k1,elCount(Dbuf));
    Re=atol(Dbuf);
  }
  else Re=-1;
  State_TIME_=getValue(StateMachine_TIME);
  return Re;
  
}

