long OSC_CANConfig(long B, long Source,long BitRate,long SampPoint,long DisplayFormat,long DisplayType,
                   long Position,float TrigLevel,long SignalType)
{
  char Sbuf[100];
  char Dbuf[100];
  char BTemp[10];
  char SourceTemp[10];
  char BitRateTemp[10];
  char SampPointTemp[10];
  char DisplayFormatTemp[10];
  char DisplayTypeTemp[10];
  char PositionTemp[10];
  char TrigLevelTemp[20];
  char SignalTypeTemp[10];
  long Re=0;
  
  ltoa(B,BTemp,10);
  ltoa(Source,SourceTemp,10);
  ltoa(BitRate,BitRateTemp,10);
  ltoa(SampPoint,SampPointTemp,10);
  ltoa(DisplayFormat,DisplayFormatTemp,10);
  ltoa(DisplayType,DisplayTypeTemp,10);
  ltoa(Position,PositionTemp,10);
  snprintf(TrigLevelTemp,elCount(TrigLevelTemp),"%.15f",TrigLevel);
  ltoa(SignalType,SignalTypeTemp,10);
  
  
  strncpy(Sbuf,"",elCount(Sbuf));
  strncat(Sbuf,"OSC_CANConfig@",elCount(Sbuf));
  strncat(Sbuf,BTemp,elCount(Sbuf));
  strncat(Sbuf,"@",elCount(Sbuf));
  strncat(Sbuf,SourceTemp,elCount(Sbuf));
  strncat(Sbuf,"@",elCount(Sbuf));
  strncat(Sbuf,BitRateTemp,elCount(Sbuf));
  strncat(Sbuf,"@",elCount(Sbuf)); 
  strncat(Sbuf,SampPointTemp,elCount(Sbuf));
  strncat(Sbuf,"@",elCount(Sbuf)); 
  strncat(Sbuf,DisplayFormatTemp,elCount(Sbuf));
  strncat(Sbuf,"@",elCount(Sbuf));   
  strncat(Sbuf,DisplayTypeTemp,elCount(Sbuf));
  strncat(Sbuf,"@",elCount(Sbuf));   
  strncat(Sbuf,PositionTemp,elCount(Sbuf));
  strncat(Sbuf,"@",elCount(Sbuf)); 
  strncat(Sbuf,TrigLevelTemp,elCount(Sbuf));
  strncat(Sbuf,"@",elCount(Sbuf)); 
  strncat(Sbuf,SignalTypeTemp,elCount(Sbuf));
  strncat(Sbuf,"@",elCount(Sbuf)); 
    
  putValue(CAPL_String,Sbuf);
  testWaitForTimeout(1);
  putValue(CAPL_TIME,timeNow());
  while(1)
  {
    if(getValue(StateMachine_TIME)!=State_TIME_)
    {
      getValue(StateMachine_String,State_String_);
      break;
    }
    testWaitForTimeout(1);
  }
  k1=strstr_off(State_String_,0,"@");
  if(k1>0)
  {
    substr_cpy(Dbuf,State_String_,0,k1,elCount(Dbuf));
    Re=atol(Dbuf);
  }
  else Re=-1;
  State_TIME_=getValue(StateMachine_TIME);
  return Re;
}

