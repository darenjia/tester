      Enable_lastmsg.byte(2)=0x00;
      output(Enable_lastmsg);
    }
    else
    {
      Enable_lastmsg.ID = 0x102;//针对Local、Gwateway盒子
      Enable_lastmsg.dlc = 8;
      Enable_lastmsg.msgChannel=2;
      Enable_lastmsg.byte(0)=0x1F;
      Enable_lastmsg.byte(1)=0xC0;
      Enable_lastmsg.byte(2)=0xC0;
      output(Enable_lastmsg);
    }
  }   
}
on timer SlaveRoundTimer
{
  int j=0;
  int k=0;
  for(j=0;j<T_online_DUTnumber;j++)
  {
    if(strncmp(DUTname2,DUT[j].name,strlen(DUTname2))==0)
    {
      break;
    }
  }
  k=DUT[j].Slavebox;
  Slave_lastmsg[k].ID =DUT[j].Slavebox;
  Slave_lastmsg[k].dlc = 8;
  
  if(SlaveCaseEnable==1)  //CAN_Initial
  {
    if(res==1)
    {
      Slave_lastmsg[k].qword(0)=message_bit_set(0,5,31,Slave_lastmsg[k].qword(0));
      if(DUT[j].TerminalR == 1)
        Slave_lastmsg[k].qword(0)=message_bit_set(14,2,03,Slave_lastmsg[k].qword(0));
      else
        Slave_lastmsg[k].qword(0)=message_bit_set(12,4,15,Slave_lastmsg[k].qword(0));
      Slave_lastmsg[k].qword(0)=message_bit_set(22,2,03,Slave_lastmsg[k].qword(0));
      output(Slave_lastmsg[k]);
    }
    else
    {
      Slave_lastmsg[k].qword(0)=message_bit_set(0,5,00,Slave_lastmsg[k].qword(0));
      Slave_lastmsg[k].qword(0)=message_bit_set(14,2,00,Slave_lastmsg[k].qword(0));
      Slave_lastmsg[k].qword(0)=message_bit_set(22,2,00,Slave_lastmsg[k].qword(0));
      output(Slave_lastmsg[k]);
    }
  } 
  
  
  if(SlaveCaseEnable==2)  //poweroff
  {
    if(res==1)
    {
      Slave_lastmsg[k].qword(0)=message_bit_set(0,4,00,Slave_lastmsg[k].qword(0));
      output(Slave_lastmsg[k]);
    }
    else
    {
      Slave_lastmsg[k].qword(0)=message_bit_set(0,4,15,Slave_lastmsg[k].qword(0));
      output(Slave_lastmsg[k]);
    }
  }
  if(SlaveCaseEnable==3)  //gndoff
  {
    if(res==1)
    {
      Slave_lastmsg[k].qword(0)=message_bit_set(4,1,00,Slave_lastmsg[k].qword(0));
      output(Slave_lastmsg[k]);
    }
    else
    {
      Slave_lastmsg[k].qword(0)=message_bit_set(4,1,01,Slave_lastmsg[k].qword(0));
      output(Slave_lastmsg[k]);
    }
  }
  if(SlaveCaseEnable==4)  //ACCoff
  {
    if(res==1)
    {
      Slave_lastmsg[k].qword(0)=message_bit_set(3,1,00,Slave_lastmsg[k].qword(0));
      output(Slave_lastmsg[k]);
    }
    else
    {
      Slave_lastmsg[k].qword(0)=message_bit_set(3,1,01,Slave_lastmsg[k].qword(0));
      output(Slave_lastmsg[k]);
    }
  }
  if(SlaveCaseEnable==5)  //IG1off
  {
    if(res==1)
    {
      Slave_lastmsg[k].qword(0)=message_bit_set(1,1,00,Slave_lastmsg[k].qword(0));
      output(Slave_lastmsg[k]);
    }
    else
    {
      Slave_lastmsg[k].qword(0)=message_bit_set(1,1,01,Slave_lastmsg[k].qword(0));
      output(Slave_lastmsg[k]);
    }
  }
  if(SlaveCaseEnable==6)  //IG2off
  {
    if(res==1)
    {
      Slave_lastmsg[k].qword(0)=message_bit_set(2,1,00,Slave_lastmsg[k].qword(0));
      output(Slave_lastmsg[k]);
    }
    else
    {
      Slave_lastmsg[k].qword(0)=message_bit_set(2,1,01,Slave_lastmsg[k].qword(0));
      output(Slave_lastmsg[k]);
    }
  }
  if(SlaveCaseEnable==7)  //gnd_offset
  {
    if(res==1)
    {
      Slave_lastmsg[k].qword(0)=message_bit_set(4,1,00,Slave_lastmsg[k].qword(0));//????????
      Slave_lastmsg[k].qword(0)=message_bit_set(5,2,03,Slave_lastmsg[k].qword(0));//????????
      output(Slave_lastmsg[k]);
    }
    else
    {
      Slave_lastmsg[k].qword(0)=message_bit_set(4,1,01,Slave_lastmsg[k].qword(0));//????????
      Slave_lastmsg[k].qword(0)=message_bit_set(5,2,00,Slave_lastmsg[k].qword(0));//????????
      output(Slave_lastmsg[k]);
    }
  } 
  if(SlaveCaseEnable==8)  //CANHoff
  {
    if(res==1)
    {
      Slave_lastmsg[k].qword(0)=message_bit_set(14,1,00,Slave_lastmsg[k].qword(0));//????????
      output(Slave_lastmsg[k]);
    }
    else
    {
      Slave_lastmsg[k].qword(0)=message_bit_set(14,1,01,Slave_lastmsg[k].qword(0));//????????
      output(Slave_lastmsg[k]);
    }
  }   
  if(SlaveCaseEnable==9)  //CANLoff
  {
    if(res==1)
    {
      Slave_lastmsg[k].qword(0)=message_bit_set(15,1,00,Slave_lastmsg[k].qword(0));//????????
      output(Slave_lastmsg[k]);
    }
    else
    {
      Slave_lastmsg[k].qword(0)=message_bit_set(15,1,01,Slave_lastmsg[k].qword(0));//????????
      output(Slave_lastmsg[k]);
    }
  }   
  if(SlaveCaseEnable==10)  //CANHLoff
  {
    if(res==1)
    {
      Slave_lastmsg[k].qword(0)=message_bit_set(14,2,00,Slave_lastmsg[k].qword(0));//????????
      output(Slave_lastmsg[k]);
    }
    else
    {
      Slave_lastmsg[k].qword(0)=message_bit_set(14,2,03,Slave_lastmsg[k].qword(0));//????????
      output(Slave_lastmsg[k]);
    }
  } 
  if(SlaveCaseEnable==11)  //CANH_R_CANL
  {
    if(res==1)
    {
      Slave_lastmsg[k].qword(0)=message_bit_set(12,2,03,Slave_lastmsg[k].qword(0));//????????
      output(Slave_lastmsg[k]);
    }
    else
    {
      Slave_lastmsg[k].qword(0)=message_bit_set(12,2,00,Slave_lastmsg[k].qword(0));//????????
      output(Slave_lastmsg[k]);
    }
  }
}
void ANetTslaveboxcontrol_sys(char Type[],int enable)//被控制的所有盒子进行何种操作
{
  int i,j;
  int trig=0;
  char ordername[20][50];
  int k=0;
  strncpy (ordername[0],"ACCoff",elcount(ordername[0]));
  strncpy (ordername[1],"IG1off",elcount(ordername[1]));
  strncpy (ordername[2],"IG2off",elcount(ordername[2]));
  strncpy (ordername[3],"poweroff",elcount(ordername[3]));
 
  trig=0;
  for(i=0;i<100;i++)
  {
    if(strncmp(Type,ordername[i],strlen(Type))==0)
     {
      trig=1;
      break;
     }
  }
  

 if(trig==1)
 {
  if(i==0)//ACCoff
  {
    if(enable==1)
    {
      for(j=0;j<T_online_DUTnumber;j++)
      {
        k=DUT[j].Slavebox;
        Slave_lastmsg[k].ID = DUT[j].Slavebox;
        Slave_lastmsg[k].dlc = 8;
        Slave_lastmsg[k].qword(0)=message_bit_set(3,1,00,Slave_lastmsg[k].qword(0));
        output(Slave_lastmsg[k]);
        write("ACCoff");
      }
    }
    else
    {
      for(j=0;j<T_online_DUTnumber;j++)
      {
        k=DUT[j].Slavebox;
        Slave_lastmsg[k].ID = DUT[j].Slavebox;
        Slave_lastmsg[k].dlc = 8;
        Slave_lastmsg[k].qword(0)=message_bit_set(3,1,01,Slave_lastmsg[k].qword(0));
        output(Slave_lastmsg[k]);
        write("ACCoff??");
      }
    }
  }
  if(i==1)//IG1off
  {
    if(enable==1)
    {
      for(j=0;j<T_online_DUTnumber;j++)
      {
        k=DUT[j].Slavebox;
        Slave_lastmsg[k].ID = DUT[j].Slavebox;
        Slave_lastmsg[k].dlc = 8;
        Slave_lastmsg[k].qword(0)=message_bit_set(1,1,00,Slave_lastmsg[k].qword(0));
        output(Slave_lastmsg[k]);
        write("IG1off");
      }
    }
    else
    {
      for(j=0;j<T_online_DUTnumber;j++)
      {
       k=DUT[j].Slavebox;
        Slave_lastmsg[k].ID = DUT[j].Slavebox;
        Slave_lastmsg[k].dlc = 8;
        Slave_lastmsg[k].qword(0)=message_bit_set(1,1,01,Slave_lastmsg[k].qword(0));
        output(Slave_lastmsg[k]);
        write("IG1off??");
      }
    }
  }
  if(i==2)//IG2off
  {
    if(enable==1)
    {
      for(j=0;j<T_online_DUTnumber;j++)
      {
        k=DUT[j].Slavebox;
        Slave_lastmsg[k].ID = DUT[j].Slavebox;
        Slave_lastmsg[k].dlc = 8;
        Slave_lastmsg[k].qword(0)=message_bit_set(2,1,00,Slave_lastmsg[k].qword(0));
        output(Slave_lastmsg[k]);
        write("IG2off");
      }
    }
    else
    {
      for(j=0;j<T_online_DUTnumber;j++)
      {
       k=DUT[j].Slavebox;
        Slave_lastmsg[k].ID = DUT[j].Slavebox;
        Slave_lastmsg[k].dlc = 8;
        Slave_lastmsg[k].qword(0)=message_bit_set(2,1,01,Slave_lastmsg[k].qword(0));
        output(Slave_lastmsg[k]);
        write("IG2off??");
      }
    }
  }
  if(i==3)//poweroff
  {
    if(enable==1)
    {
      for(j=0;j<T_online_DUTnumber;j++)
      {
       k=DUT[j].Slavebox;
        Slave_lastmsg[k].ID = DUT[j].Slavebox;
        Slave_lastmsg[k].dlc = 8;
        Slave_lastmsg[k].qword(0)=message_bit_set(0,1,00,Slave_lastmsg[k].qword(0));
        output(Slave_lastmsg[k]);
      }
    }
    else
    {
      for(j=0;j<T_online_DUTnumber;j++)
      {
       k=DUT[j].Slavebox;
        Slave_lastmsg[k].ID = DUT[j].Slavebox;
        Slave_lastmsg[k].dlc = 8;
        Slave_lastmsg[k].qword(0)=message_bit_set(0,1,01,Slave_lastmsg[k].qword(0));
        output(Slave_lastmsg[k]);
      }
    }
  }
  Testwaitfortimeout(10);
 }
}


