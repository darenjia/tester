void TestInit_OnlyKL30(int mode)  //测试初始化上电
{
  sysvar::VTS::M1_VT7001.SetInterconnectionMode(1);//VT7001电源模式设置SUP1
//  POW_CurrOutSetup(5);testWaitForTimeout(500);
//  POW_VoltOutSetup(24);testWaitForTimeout(500);
  POW_OutputSwitch(1);
  testWaitForTimeout(100);  //用于等效电源启动过程的等待延时  
  
  CASE_TJ_CAN1(1);  

  K30_on();
  Gnd_on();

  writetolog("----------测试初始化上电----------");
}


CANH_off(int State)
{
  if(State==1)
  {
    ErrorFlag++;
    //@sysvar::VTS::M3_Ch5::Relay = 0;
    @sysvar::VTS::M3_Ch19::Relay = 0;
    sysSetVariableInt(sysvar::VTS::M2_NewConfig::PCA9506_Std_2,message_bit_set_sys(sysvar::VTS::M2_NewConfig::PCA9506_Std_2,1,1,ErrorFlag%2));
    Testwaitfortimeout(5);
    writeToLog("=======CANH断路=======");
    RefValueToSystemVar("CANH断路"); 
  }
  if(State==0)
  {
    ErrorFlag++;
   // @sysvar::VTS::M3_Ch5::Relay = 1;
    @sysvar::VTS::M3_Ch19::Relay = 1;
    sysSetVariableInt(sysvar::VTS::M2_NewConfig::PCA9506_Std_2,message_bit_set_sys(sysvar::VTS::M2_NewConfig::PCA9506_Std_2,1,1,ErrorFlag%2));
    //Testwaitfortimeout(500);
    writeToLog("=======CANH断路恢复分析记录文件=======");
    RefValueToSystemVar("CANH断路恢复"); 
  }
}

CANL_off(int State)
{
  if(State==1)
  {
    ErrorFlag++;
    @sysvar::VTS::M3_Ch6::Relay = 0;
    sysSetVariableInt(sysvar::VTS::M2_NewConfig::PCA9506_Std_2,message_bit_set_sys(sysvar::VTS::M2_NewConfig::PCA9506_Std_2,1,1,ErrorFlag%2));
    Testwaitfortimeout(5);
    writeToLog("=======CANL断路=======");
    RefValueToSystemVar("CANL断路"); 
  }
  if(State==0)
  {
    ErrorFlag++;
    @sysvar::VTS::M3_Ch6::Relay = 1;
    sysSetVariableInt(sysvar::VTS::M2_NewConfig::PCA9506_Std_2,message_bit_set_sys(sysvar::VTS::M2_NewConfig::PCA9506_Std_2,1,1,ErrorFlag%2));
    //Testwaitfortimeout(500);
    writeToLog("=======CANL断路恢复分析记录文件=======");
    RefValueToSystemVar("CANL断路恢复"); 
  }
}

