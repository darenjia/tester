{
 if(mode==1)//接120欧终端1
  {
    sysSetVariableInt(sysvar::VTS::M2_NewConfig::PCA9506_Std_3,message_bit_set_sys(sysvar::VTS::M2_NewConfig::PCA9506_Std_3,7,1,1));
    sysSetVariableInt(sysvar::VTS::M2_NewConfig::PCA9506_Std_4,message_bit_set_sys(sysvar::VTS::M2_NewConfig::PCA9506_Std_4,3,1,1));
  }
 if(mode==0)//不接120欧终端1
  {
    sysSetVariableInt(sysvar::VTS::M2_NewConfig::PCA9506_Std_3,message_bit_set_sys(sysvar::VTS::M2_NewConfig::PCA9506_Std_3,7,1,0));
    sysSetVariableInt(sysvar::VTS::M2_NewConfig::PCA9506_Std_4,message_bit_set_sys(sysvar::VTS::M2_NewConfig::PCA9506_Std_4,3,1,0));
  }
}

CAN_120_2(int mode)
{
 if(mode==1)//接120欧终端2
  {
    sysSetVariableInt(sysvar::VTS::M2_NewConfig::PCA9506_Std_3,message_bit_set_sys(sysvar::VTS::M2_NewConfig::PCA9506_Std_3,5,1,1));
    sysSetVariableInt(sysvar::VTS::M2_NewConfig::PCA9506_Std_3,message_bit_set_sys(sysvar::VTS::M2_NewConfig::PCA9506_Std_3,3,1,1));
  }
 if(mode==0)//不接120欧终端2
  {
    sysSetVariableInt(sysvar::VTS::M2_NewConfig::PCA9506_Std_3,message_bit_set_sys(sysvar::VTS::M2_NewConfig::PCA9506_Std_3,5,1,0));
    sysSetVariableInt(sysvar::VTS::M2_NewConfig::PCA9506_Std_3,message_bit_set_sys(sysvar::VTS::M2_NewConfig::PCA9506_Std_3,3,1,0));
  }
}