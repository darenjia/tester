CANH_ShortToPower(int State)
{
  if(State==1)
  {
    ErrorFlag++;
    sysSetVariableInt(sysvar::VTS::M2_NewConfig::PCA9506_Std_2,message_bit_set_sys(sysvar::VTS::M2_NewConfig::PCA9506_Std_2,1,1,ErrorFlag%2));
    testWaitForTimeout(2.5);
    sysSetVariableInt(sysvar::VTS::M2_NewConfig::PCA9506_Std_2,message_bit_set_sys(sysvar::VTS::M2_NewConfig::PCA9506_Std_2,5,1,1));
    sysSetVariableInt(sysvar::VTS::M2_NewConfig::PCA9506_Std_3,message_bit_set_sys(sysvar::VTS::M2_NewConfig::PCA9506_Std_3,6,1,1));
    writeToLog("=======CANH短电=======");
    RefValueToSystemVar("CANH短电"); 
  }
  if(State==0)
  {
    ErrorFlag++;
    sysSetVariableInt(sysvar::VTS::M2_NewConfig::PCA9506_Std_2,message_bit_set_sys(sysvar::VTS::M2_NewConfig::PCA9506_Std_2,1,1,ErrorFlag%2));
    testWaitForTimeout(2.5);
    sysSetVariableInt(sysvar::VTS::M2_NewConfig::PCA9506_Std_2,message_bit_set_sys(sysvar::VTS::M2_NewConfig::PCA9506_Std_2,5,1,1));
    sysSetVariableInt(sysvar::VTS::M2_NewConfig::PCA9506_Std_3,message_bit_set_sys(sysvar::VTS::M2_NewConfig::PCA9506_Std_3,6,1,0));
    //Testwaitfortimeout(500); 
    writeToLog("=======CANH短电恢复分析记录文件=======");
    RefValueToSystemVar("CANH短电恢复"); 
  }
}

