/*----- 测试上电/下电初始化控制 -----*/
void TestInit_sys(int mode)  //测试初始化上电
{
  sysvar::VTS::M1_VT7001.SetInterconnectionMode(1);//VT7001电源模式设置SUP1
  KL_on(); 
  Gnd_on();
  CAN_120_1(0);
  CAN_120_2(0);
//  POW_CurrOutSetup(5);testWaitForTimeout(500);
//  POW_VoltOutSetup(24);testWaitForTimeout(3000);
  POW_OutputSwitch(1); 

  CASE_TJ_CAN1(1);  
  testWaitForTimeout(1000);
 }

void ANetTslaveboxcontrol_CANInitial()//选取的盒子全部进行CAN初始化
{
  int j=0;
  int k=0,n;
   k=0;
   n=0;
   j=0;       
  for(j=0;j<T_online_DUTnumber;j++)
  {
    k=DUT[j].Slavebox;
    Slave_lastmsg[k].ID=DUT[j].Slavebox;
    Slave_lastmsg[k].dlc=8;
    Slave_lastmsg[k].msgChannel=2;
    Slave_lastmsg[k].byte(0)=0X1f;//上电和地
    Slave_lastmsg[k].byte(1)=0XC0;//上CAN1线  
    Slave_lastmsg[k].byte(2)=0XC0;//网关的话上CAN2线
    Slave_lastmsg[k].byte(3)=0X00;
    Slave_lastmsg[k].byte(4)=0X00;
    Slave_lastmsg[k].byte(5)=0;
    Slave_lastmsg[k].byte(6)=0;
    Slave_lastmsg[k].byte(7)=0;
    
//    if (TestChannel==1)//CAN1????
//     {
//      Slave_lastmsg[k].qword(0)=message_bit_set(8,2,03,Slave_lastmsg[k].qword(0));
//      write("CAN1????");
//     }
//    else if(TestChannel==2)//CAN2????
//     {
//      WRITE("HEREJJJJJJJJ");
//      Slave_lastmsg[k].qword(0)=message_bit_set(10,2,03,Slave_lastmsg[k].qword(0));
//      write("CAN2????");
//     }
//     else if(TestChannel==3)//CAN3????
//     {
//      Slave_lastmsg[k].qword(0)=message_bit_set(12,2,03,Slave_lastmsg[k].qword(0));
//     }
//     else if(TestChannel==4)//CAN4????
//     {
//      Slave_lastmsg[k].qword(0)=message_bit_set(14,2,03,Slave_lastmsg[k].qword(0));
//     }
  
    output(Slave_lastmsg[k]);   
  }
  Testwaitfortimeout(10);
}
void ANetTslaveboxcontrol()//发0x100报文使能
{
  Enable_lastmsg.ID = 0X100;
  Enable_lastmsg.dlc = 8;
  Enable_lastmsg.msgChannel=2;
  output(Enable_lastmsg);
  Testwaitfortimeout(10);
}
void ANetT0x100slaveboxNotReponse()//发0x120报文使得盒子不返回自身ID
{
  Enable_lastmsg.ID = 0X120;
  Enable_lastmsg.dlc = 8;
  Enable_lastmsg.msgChannel=2;
  Enable_lastmsg.byte(0) = 0X1;
  output(Enable_lastmsg);
  Testwaitfortimeout(10);
}
void ANetTslaveboxcontrol_alldrop()//控制所有盒子同时断开
{
  Enable_lastmsg.ID = 0x101;//针对Local、Gwateway盒子
  Enable_lastmsg.dlc = 8;
  Enable_lastmsg.msgChannel=2;
  Enable_lastmsg.byte(0)=0;
  output(Enable_lastmsg);
  Testwaitfortimeout(2);
  Enable_lastmsg.ID = 0x103;//针对I/O盒子
  Enable_lastmsg.dlc = 8;
  Enable_lastmsg.msgChannel=2;
  Enable_lastmsg.byte(0)=0;
  output(Enable_lastmsg);
  Testwaitfortimeout(2);
  Enable_lastmsg.ID = 0x104;//针对Global盒子
  Enable_lastmsg.dlc = 8;
  Enable_lastmsg.msgChannel=2;
  Enable_lastmsg.byte(0)=0;
  output(Enable_lastmsg);
  Testwaitfortimeout(2);
  
  
}
void ANetTslaveboxcontrol(char DUTname1[],char Type[],int enable)//被控制的单个盒子进行何种操作
{

  int i;
  char SlaveBoxCase[50][50];
  
  strncpy (SlaveBoxCase[1],"CAN_Initial",elcount(SlaveBoxCase[1]));
  strncpy (SlaveBoxCase[2],"poweroff",elcount(SlaveBoxCase[2]));
  strncpy (SlaveBoxCase[3],"gndoff",elcount(SlaveBoxCase[3]));
  strncpy (SlaveBoxCase[4],"ACCoff",elcount(SlaveBoxCase[4]));
  strncpy (SlaveBoxCase[5],"IG1off",elcount(SlaveBoxCase[5]));
  strncpy (SlaveBoxCase[6],"IG2off",elcount(SlaveBoxCase[6]));
  strncpy (SlaveBoxCase[7],"gnd_offset",elcount(SlaveBoxCase[7]));
  strncpy (SlaveBoxCase[8],"CANHoff",elcount(SlaveBoxCase[8]));
  strncpy (SlaveBoxCase[9],"CANLoff",elcount(SlaveBoxCase[9]));
  strncpy (SlaveBoxCase[10],"CANHLoff",elcount(SlaveBoxCase[10]));
  strncpy (SlaveBoxCase[11],"CANH_R_CANL",elcount(SlaveBoxCase[11]));
  
  strncpy (DUTname2,DUTname1,elcount(DUTname2));

  for(i=1;i<100;i++)
  {
    if(strncmp(Type,SlaveBoxCase[i],strlen(Type))==0)
    {
      SlaveCaseEnable=i;
      res=enable;
      break;
    }
  }
  setTimer(SlaveRoundTimer,5);
  Testwaitfortimeout(10);
}
void ANetT_Allslaveboxcontrol(char Type[],int enable)//控制所有盒子进行何种操作
{

  int i;
  char SlaveBoxCase[50][50];
  
  strncpy (SlaveBoxCase[1],"CAN_Initial",elcount(SlaveBoxCase[1]));
  strncpy (SlaveBoxCase[2],"poweroff",elcount(SlaveBoxCase[2]));
  strncpy (SlaveBoxCase[3],"gndoff",elcount(SlaveBoxCase[3]));
  strncpy (SlaveBoxCase[4],"ACCoff",elcount(SlaveBoxCase[4]));
  strncpy (SlaveBoxCase[5],"IG1off",elcount(SlaveBoxCase[5]));
  strncpy (SlaveBoxCase[6],"IG2off",elcount(SlaveBoxCase[6]));
  strncpy (SlaveBoxCase[7],"gnd_offset",elcount(SlaveBoxCase[7]));
  strncpy (SlaveBoxCase[8],"CANHoff",elcount(SlaveBoxCase[8]));
  strncpy (SlaveBoxCase[9],"CANLoff",elcount(SlaveBoxCase[9]));
  strncpy (SlaveBoxCase[10],"CANHLoff",elcount(SlaveBoxCase[10]));
  strncpy (SlaveBoxCase[11],"CANH_R_CANL",elcount(SlaveBoxCase[11]));
  

  for(i=1;i<100;i++)
  {
    if(strncmp(Type,SlaveBoxCase[i],strlen(Type))==0)
    {
      SlaveCaseEnable=i;
      res=enable;
      break;
    }
  }
  if(SlaveCaseEnable==1)  //CAN_Initial
  {
    if(res==1)
    {
      Enable_lastmsg.ID = 0x102;//针对Local、Gwateway盒子
      Enable_lastmsg.dlc = 8;
      Enable_lastmsg.msgChannel=2;
      Enable_lastmsg.byte(0)=0x1F;
      Enable_lastmsg.byte(1)=0xC0;
      Enable_lastmsg.byte(2)=0xC0;
      output(Enable_lastmsg);
    }
    else
    {
      Enable_lastmsg.ID = 0x102;//针对Local、Gwateway盒子
      Enable_lastmsg.dlc = 8;
      Enable_lastmsg.msgChannel=2;
      Enable_lastmsg.byte(0)=0x1F;
      Enable_lastmsg.byte(1)=0xC0;
      Enable_lastmsg.byte(2)=0xC0;
      output(Enable_lastmsg);
    }
  } 
  if(SlaveCaseEnable==2)  //poweroff
  {
    if(res==1)
    {
      Enable_lastmsg.ID = 0x102;//针对Local、Gwateway盒子
      Enable_lastmsg.dlc = 8;
      Enable_lastmsg.msgChannel=2;
      Enable_lastmsg.byte(0)=0x10;
      Enable_lastmsg.byte(1)=0xC0;
      Enable_lastmsg.byte(2)=0xC0;
      output(Enable_lastmsg);
    }
    else
    {
      Enable_lastmsg.ID = 0x102;//针对Local、Gwateway盒子
      Enable_lastmsg.dlc = 8;
      Enable_lastmsg.msgChannel=2;
      Enable_lastmsg.byte(0)=0x1F;
      Enable_lastmsg.byte(1)=0xC0;
      Enable_lastmsg.byte(2)=0xC0;
      output(Enable_lastmsg);
    }
  }   
  if(SlaveCaseEnable==3)  //gndoff
  {
    if(res==1)
    {
      Enable_lastmsg.ID = 0x102;//针对Local、Gwateway盒子
      Enable_lastmsg.dlc = 8;
      Enable_lastmsg.msgChannel=2;
      Enable_lastmsg.byte(0)=0x0F;
      Enable_lastmsg.byte(1)=0xC0;
      Enable_lastmsg.byte(2)=0xC0;
      output(Enable_lastmsg);
    }
    else
    {
      Enable_lastmsg.ID = 0x102;//针对Local、Gwateway盒子
      Enable_lastmsg.dlc = 8;
      Enable_lastmsg.msgChannel=2;
      Enable_lastmsg.byte(0)=0x1F;
      Enable_lastmsg.byte(1)=0xC0;
      Enable_lastmsg.byte(2)=0xC0;
      output(Enable_lastmsg);
    }
  }   
  if(SlaveCaseEnable==4)  //ACCoff
  {
    if(res==1)
    {
      Enable_lastmsg.ID = 0x102;//针对Local、Gwateway盒子
      Enable_lastmsg.dlc = 8;
      Enable_lastmsg.msgChannel=2;
      Enable_lastmsg.byte(0)=0x17;
      Enable_lastmsg.byte(1)=0xC0;
      Enable_lastmsg.byte(2)=0xC0;
      output(Enable_lastmsg);
    }
    else
    {
      Enable_lastmsg.ID = 0x102;//针对Local、Gwateway盒子
      Enable_lastmsg.dlc = 8;
      Enable_lastmsg.msgChannel=2;
      Enable_lastmsg.byte(0)=0x1F;
      Enable_lastmsg.byte(1)=0xC0;
      Enable_lastmsg.byte(2)=0xC0;
      output(Enable_lastmsg);
    }
  }   
  if(SlaveCaseEnable==5)  //IG1off
  {
    if(res==1)
    {
      Enable_lastmsg.ID = 0x102;//针对Local、Gwateway盒子
      Enable_lastmsg.dlc = 8;
      Enable_lastmsg.msgChannel=2;
      Enable_lastmsg.byte(0)=0x1D;
      Enable_lastmsg.byte(1)=0xC0;
      Enable_lastmsg.byte(2)=0xC0;
      output(Enable_lastmsg);
    }
    else
    {
      Enable_lastmsg.ID = 0x102;//针对Local、Gwateway盒子
      Enable_lastmsg.dlc = 8;
      Enable_lastmsg.msgChannel=2;
      Enable_lastmsg.byte(0)=0x1F;
      Enable_lastmsg.byte(1)=0xC0;
      Enable_lastmsg.byte(2)=0xC0;
      output(Enable_lastmsg);
    }
  }   
  if(SlaveCaseEnable==6)  //IG2off
  {
    if(res==1)
    {
      Enable_lastmsg.ID = 0x102;//针对Local、Gwateway盒子
      Enable_lastmsg.dlc = 8;
      Enable_lastmsg.msgChannel=2;
      Enable_lastmsg.byte(0)=0x1B;
      Enable_lastmsg.byte(1)=0xC0;
      Enable_lastmsg.byte(2)=0xC0;
      output(Enable_lastmsg);
    }
    else
    {
      Enable_lastmsg.ID = 0x102;//针对Local、Gwateway盒子
      Enable_lastmsg.dlc = 8;
      Enable_lastmsg.msgChannel=2;
      Enable_lastmsg.byte(0)=0x1F;
      Enable_lastmsg.byte(1)=0xC0;
      Enable_lastmsg.byte(2)=0xC0;
      output(Enable_lastmsg);
    }
  }

  if(SlaveCaseEnable==8)  //CANHoff
  {
    if(res==1)
    {
      Enable_lastmsg.ID = 0x102;//针对Local、Gwateway盒子
      Enable_lastmsg.dlc = 8;
      Enable_lastmsg.msgChannel=2;
      Enable_lastmsg.byte(0)=0x1F;
      Enable_lastmsg.byte(1)=0x80;
      Enable_lastmsg.byte(2)=0x80;
      output(Enable_lastmsg);
    }
    else
    {
      Enable_lastmsg.ID = 0x102;//针对Local、Gwateway盒子
      Enable_lastmsg.dlc = 8;
      Enable_lastmsg.msgChannel=2;
      Enable_lastmsg.byte(0)=0x1F;
      Enable_lastmsg.byte(1)=0xC0;
      Enable_lastmsg.byte(2)=0xC0;
      output(Enable_lastmsg);
    }
  } 
  if(SlaveCaseEnable==9)  //CANLoff
  {
    if(res==1)
    {
      Enable_lastmsg.ID = 0x102;//针对Local、Gwateway盒子
      Enable_lastmsg.dlc = 8;
      Enable_lastmsg.msgChannel=2;
      Enable_lastmsg.byte(0)=0x1F;
      Enable_lastmsg.byte(1)=0x40;
      Enable_lastmsg.byte(2)=0x40;
      output(Enable_lastmsg);
    }
    else
    {
      Enable_lastmsg.ID = 0x102;//针对Local、Gwateway盒子
      Enable_lastmsg.dlc = 8;
      Enable_lastmsg.msgChannel=2;
      Enable_lastmsg.byte(0)=0x1F;
      Enable_lastmsg.byte(1)=0xC0;
      Enable_lastmsg.byte(2)=0xC0;
      output(Enable_lastmsg);
    }
  }   
  if(SlaveCaseEnable==10)  //CANHLoff
  {
    if(res==1)
    {
      Enable_lastmsg.ID = 0x102;//针对Local、Gwateway盒子
