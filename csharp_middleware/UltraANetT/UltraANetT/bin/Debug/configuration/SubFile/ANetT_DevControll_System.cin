  if(State==0)
  {
    ErrorFlag++;
    sysSetVariableInt(sysvar::VTS::M2_NewConfig::PCA9506_Std_2,message_bit_set_sys(sysvar::VTS::M2_NewConfig::PCA9506_Std_2,1,1,ErrorFlag%2));
    testWaitForTimeout(2.5);
    sysSetVariableInt(sysvar::VTS::M2_NewConfig::PCA9506_Std_2,message_bit_set_sys(sysvar::VTS::M2_NewConfig::PCA9506_Std_2,5,1,0));
    sysSetVariableInt(sysvar::VTS::M2_NewConfig::PCA9506_Std_3,message_bit_set_sys(sysvar::VTS::M2_NewConfig::PCA9506_Std_3,2,1,0));
    //Testwaitfortimeout(500); 
    writeToLog("=======CANH短地恢复分析记录文件=======");
    RefValueToSystemVar("CANH短地恢复"); 
  }
}

