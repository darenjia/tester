    substr_cpy(Dbuf3,State_String_,k2+1,k3-k2-1,elCount(Dbuf3));
    substr_cpy(Dbuf4,State_String_,k3+1,k4-k3-1,elCount(Dbuf4));
    write("调度表个数==:%s",Dbuf1);
    write("ST_ID==:%s",Dbuf2);
    write("STDelay==:%s",Dbuf3);
    write("DLC==:%s",Dbuf4);
    Re=atol(Dbuf1);
    k5=-1;
    for(i=0;i<500;i++)
    {
      if(strstr_off(Dbuf2,k5+1,"#")<=0) break;
      for(j=0;j<10;j++)
      {
        IDTemp[j]=0;
      }
      substr_cpy(IDTemp,Dbuf2,k5+1,strstr_off(Dbuf2,k5+1,"#")-k5-1,elCount(IDTemp));
      strtoul(IDTemp,ST_ID[i]);
      k5=strstr_off(Dbuf2,k5+1,"#");
    }
        k6=-1;
    for(i=0;i<500;i++)
    {
      if(strstr_off(Dbuf3,k6+1,"#")<=0) break;
      for(j=0;j<10;j++)
      {
        IDDelayTemp[j]=0;
      }
      substr_cpy(IDDelayTemp,Dbuf3,k6+1,strstr_off(Dbuf3,k6+1,"#")-k6-1,elCount(IDDelayTemp));
      strtol(IDDelayTemp,STDelay[i]);
      k6=strstr_off(Dbuf3,k6+1,"#");
