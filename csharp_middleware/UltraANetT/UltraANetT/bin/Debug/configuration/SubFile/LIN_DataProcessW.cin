/*@!Encoding:936*/
long ANetT_Database_LIN_File(char Path[])
{
  char Sbuf[1000];
  char Dbuf[1000];
  long Re=0;
  char absPath[1000];
  getAbsFilePath(Path,absPath,1000);
  strncpy(Sbuf,"",elCount(Sbuf));
  strncat(Sbuf,"ANetT_Database_LIN_File@",elCount(Sbuf));
  strncat(Sbuf,absPath,elCount(Sbuf));
  strncat(Sbuf,"@",elCount(Sbuf));
  putValue(CAPL_String,Sbuf);
  testWaitForTimeout(1);
  putValue(CAPL_TIME,timeNow());
  write("CAPL_TIME====%f",getValue(CAPL_TIME));
  while(1)
  {
    if(getValue(StateMachine_TIME)!=State_TIME_)
    {
      getValue(StateMachine_String,State_String_);
      write("State_String_===%s",State_String_);
      break;
    }
    testWaitForTimeout(1);
  }
  k1=strstr_off(State_String_,0,"@");
  if(k1>0)
  {
    substr_cpy(Dbuf,State_String_,0,k1,elCount(Dbuf));
    Re=atol(Dbuf);
    write("Re===%d",Re);
  }
  else Re=-1;
  State_TIME_=getValue(StateMachine_TIME);
  return Re;
}

long ANetT_Database_LINID(char DUTName[], dword ID[] , long DLC[])
{
  char Sbuf[1000];
  char Dbuf1[1000];
  char Dbuf2[1000];
  char Dbuf3[1000];
  char IDTemp[10];
  char DLCTemp[10];
  long Re=0;
  int i=0;
  int j=0;
  strncpy(Sbuf,"",elCount(Sbuf));
  strncat(Sbuf,"ANetT_Database_LINID@",elCount(Sbuf));
  strncat(Sbuf,DUTName,elCount(Sbuf));
  strncat(Sbuf,"@",elCount(Sbuf));
  putValue(CAPL_String,Sbuf);
  testWaitForTimeout(1);
  putValue(CAPL_TIME,timeNow());
  while(1)
  {
    if(getValue(StateMachine_TIME)!=State_TIME_)
    {
      getValue(StateMachine_String,State_String_);
      break;
    }
    testWaitForTimeout(100);
  }
  k1=strstr_off(State_String_,0,"@");
  k2=strstr_off(State_String_,k1+1,"@");
  k3=strstr_off(State_String_,k2+1,"@");
  if(k1>0&&k2>0&&k3>0)
  {
    substr_cpy(Dbuf1,State_String_,0,k1,elCount(Dbuf1));
    substr_cpy(Dbuf2,State_String_,k1+1,k2-k1-1,elCount(Dbuf2));
    substr_cpy(Dbuf3,State_String_,k2+1,k3-k2-1,elCount(Dbuf3));
    Re=atol(Dbuf1);
    k4=-1;
    write("ID====%s",Dbuf2);
    write("DLC====%s",Dbuf3);
    for(i=0;i<500;i++)
    {
      if(strstr_off(Dbuf2,k4+1,"#")<=0) break;
      for(j=0;j<10;j++)
      {
        IDTemp[j]=0;
      }
      substr_cpy(IDTemp,Dbuf2,k4+1,strstr_off(Dbuf2,k4+1,"#")-k4-1,elCount(IDTemp));
      strtoul(IDTemp,ID[i]);
      k4=strstr_off(Dbuf2,k4+1,"#");
    }
    k5=-1;
    for(i=0;i<500;i++)
    {
      if(strstr_off(Dbuf3,k5+1,"#")<=0) break;
      for(j=0;j<10;j++)
      {
        DLCTemp[j]=0;
      }
      substr_cpy(DLCTemp,Dbuf3,k5+1,strstr_off(Dbuf3,k5+1,"#")-k5-1,elCount(DLCTemp));
      strtol(DLCTemp,DLC[i]);
      k5=strstr_off(Dbuf3,k5+1,"#");
    }
   }
  else Re=-1;
  State_TIME_=getValue(StateMachine_TIME);
  return Re;
}

long ANetT_Database_LINSignal(char DUTName[], dword ID[],long signal_N[],long startbit[][],long length[][])
{
  char Sbuf[1000];
  char Dbuf1[2000];
  char Dbuf2[2000];
  char Dbuf3[2000];
  char Dbuf4[2000];
  char Dbuf5[2000];
  char IDTemp[10];
  char signal_NTemp[10];
  char startbitTemp1[500];
  char startbitTemp2[10];
  char lengthTemp1[500];
  char lengthTemp2[10];
  long Re=0;
  int i=0;
  int j=0;
  int k=0;
  strncpy(Sbuf,"",elCount(Sbuf));
  strncat(Sbuf,"ANetT_Database_LINSignal@",elCount(Sbuf));
  strncat(Sbuf,DUTName,elCount(Sbuf));
  strncat(Sbuf,"@",elCount(Sbuf));
  putValue(CAPL_String,Sbuf);
  testWaitForTimeout(1);
  putValue(CAPL_TIME,timeNow());
  while(1)
  {
    if(getValue(StateMachine_TIME)!=State_TIME_)
    {
      getValue(StateMachine_String,State_String_);
      break;
    }
    testWaitForTimeout(1);
  }
  k1=strstr_off(State_String_,0,"@");//个数
  k2=strstr_off(State_String_,k1+1,"@");//ID
  k3=strstr_off(State_String_,k2+1,"@");//信号个数
  k4=strstr_off(State_String_,k3+1,"@");//STB
  k5=strstr_off(State_String_,k4+1,"@");//length
  if(k1>0&&k2>0&&k3>0&&k4>0&&k5>0)
  {
    substr_cpy(Dbuf1,State_String_,0,k1,elCount(Dbuf1));
    substr_cpy(Dbuf2,State_String_,k1+1,k2-k1-1,elCount(Dbuf2));
    substr_cpy(Dbuf3,State_String_,k2+1,k3-k2-1,elCount(Dbuf3));
    substr_cpy(Dbuf4,State_String_,k3+1,k4-k3-1,elCount(Dbuf4));
    substr_cpy(Dbuf5,State_String_,k4+1,k5-k4-1,elCount(Dbuf5));
    Re=atol(Dbuf1);
    k7=-1;
    write("ID====%s",Dbuf2);
    write("信号个数====%s",Dbuf3);
    write("STB====%s",Dbuf4);
    write("length====%s",Dbuf5);
    for(i=0;i<500;i++)
    {
      if(strstr_off(Dbuf2,k7+1,"#")<=0) break;
      for(j=0;j<10;j++)
      {
        IDTemp[j]=0;
      }
      substr_cpy(IDTemp,Dbuf2,k7+1,strstr_off(Dbuf2,k7+1,"#")-k7-1,elCount(IDTemp));
      strtoul(IDTemp,ID[i]);
      k7=strstr_off(Dbuf2,k7+1,"#");
    }
    k8=-1;
    for(i=0;i<500;i++)
    {
      if(strstr_off(Dbuf3,k8+1,"#")<=0) break;
      for(j=0;j<10;j++)
      {
        signal_NTemp[j]=0;
      }
      substr_cpy(signal_NTemp,Dbuf3,k8+1,strstr_off(Dbuf3,k8+1,"#")-k8-1,elCount(signal_NTemp));
      strtol(signal_NTemp,signal_N[i]);
      k8=strstr_off(Dbuf3,k8+1,"#");
    }
    k9=-1;
    for(i=0;i<Re;i++)
    {
      if(strstr_off(Dbuf4,k9+1,"#")<=0) break;
      for(j=0;j<signal_N[i];j++)
      {
        startbitTemp1[j]=0;
      
      substr_cpy(startbitTemp1,Dbuf4,k9+1,strstr_off(Dbuf4,k9+1,"#")-k9-1,elCount(startbitTemp1));
    
      strtol(startbitTemp1,startbit[i][j]);
      k9=strstr_off(Dbuf4,k9+1,"#");
      }
    }
    
    k10=-1;
    for(i=0;i<500;i++)
    {      
      if(strstr_off(Dbuf5,k10+1,"#")<=0) break;
      for(j=0;j<signal_N[i];j++)
      {
        lengthTemp1[j]=0;      
      substr_cpy(lengthTemp1,Dbuf5,k10+1,strstr_off(Dbuf5,k10+1,"#")-k10-1,elCount(lengthTemp1));
      strtol(lengthTemp1,length[i][j]);   
      k10=strstr_off(Dbuf5,k10+1,"#");
      }
    }

  }
  else Re=-1;
  State_TIME_=getValue(StateMachine_TIME);
  return Re;
}

