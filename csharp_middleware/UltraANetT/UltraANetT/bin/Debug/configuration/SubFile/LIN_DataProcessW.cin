long ANetT_Test_LIN_StuffBit(char Path[],dword StandardID[],long signal_N[],long startbit[][],long length[][],char Describ[])
{
  char Sbuf[1000];
  char Dbuf1[1000];
  char Dbuf2[1000];
  char Dbuf3[1000];
  char StandardIDTemp[100];
  char signal_NTemp[100];
  char startbitTemp[100];
  char lengthTemp[100];
  long Re=0;
  int i=0;
  int j=0;
  int p=0;
  int m=0;
  int n=0;
  int q=0;  
  char absPath[1000];
  getAbsFilePath(Path,absPath,1000);
  strncpy(Sbuf,"",elCount(Sbuf));
  strncat(Sbuf,"ANetT_Test_LIN_StuffBit@",elCount(Sbuf));
  strncat(Sbuf,absPath,elCount(Sbuf));
  strncat(Sbuf,"@",elCount(Sbuf));
  for(i=0;i<500;i++)
  {
    if(StandardID[i]=='\0') break;
    ltoa(StandardID[i],StandardIDTemp,16);
    strncat(Sbuf,StandardIDTemp,elCount(Sbuf));
    strncat(Sbuf,"#",elCount(Sbuf));
  }
  strncat(Sbuf,"@",elCount(Sbuf));
  for(j=0;j<500;j++)
  {
    if(signal_N[j]=='\0') break;
    ltoa(signal_N[j],signal_NTemp,10);
    strncat(Sbuf,signal_NTemp,elCount(Sbuf));
    strncat(Sbuf,"#",elCount(Sbuf));
  }
  strncat(Sbuf,"@",elCount(Sbuf));
  for(m=0;m<50;m++)
  {
    if(signal_N[m]=='\0') break;
    for(n=0;n<signal_N[m];n++)
    {
      ltoa(startbit[m][n],startbitTemp,10);
      strncat(Sbuf,startbitTemp,elCount(Sbuf));
      strncat(Sbuf,"#",elCount(Sbuf));
      //if(startbit[m][n+1]=='\0') break;
    }
  }
  strncat(Sbuf,"@",elCount(Sbuf));
  for(p=0;p<50;p++)
  {
    for(q=0;q<100;q++)
    {
      if(length[p][q]=='\0') break;
      ltoa(length[p][q],lengthTemp,10);
      strncat(Sbuf,lengthTemp,elCount(Sbuf));
      strncat(Sbuf,"#",elCount(Sbuf));
    }
  }
  write ("44444444444444444444444444444444444444444");
  strncat(Sbuf,"@",elCount(Sbuf));
