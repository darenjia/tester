      for(j=0;j<10;j++)
      {
        DLCTemp[j]=0;
      }
      substr_cpy(DLCTemp,Dbuf4,k7+1,strstr_off(Dbuf4,k7+1,"#")-k7-1,elCount(DLCTemp));
      strtol(DLCTemp,DLC[i]);
      k7=strstr_off(Dbuf4,k7+1,"#");
    }  
  }
  else Re=-1;
  State_TIME_=getValue(StateMachine_TIME);
  return Re;
}

long ANetT_Test_LINDLC(char Path[],dword StandardID[],long StandardDLC[],char Describ[])
{
  char Sbuf[1000];
  char Dbuf1[1000];
  char Dbuf2[1000];
  char Dbuf3[1000];
  char ChannelTemp[10];
  char StandardIDTemp[10];
  char StandardDLCTemp[10];
  long Re=0;
  int i=0;
  int j=0;
  char absPath[1000];
  getAbsFilePath(Path,absPath,1000);
  strncpy(Sbuf,"",elCount(Sbuf));
  strncat(Sbuf,"ANetT_Test_LINDLC@",elCount(Sbuf));
  strncat(Sbuf,absPath,elCount(Sbuf));
  strncat(Sbuf,"@",elCount(Sbuf));
  for(i=0;i<500;i++)
  {
    if(StandardID[i]=='\0') break;
    ltoa(StandardID[i],StandardIDTemp,16);
    strncat(Sbuf,StandardIDTemp,elCount(Sbuf));
    strncat(Sbuf,"#",elCount(Sbuf));
  }
  strncat(Sbuf,"@",elCount(Sbuf));
  for(j=0;j<500;j++)
  {
    if(StandardDLC[j]=='\0') break;
    ltoa(StandardDLC[j],StandardDLCTemp,10);
    strncat(Sbuf,StandardDLCTemp,elCount(Sbuf));
    strncat(Sbuf,"#",elCount(Sbuf));
  }
  strncat(Sbuf,"@",elCount(Sbuf));
  write("Sbuf======LINDLC========%s",Sbuf);
  putValue(CAPL_String,Sbuf);  
  testWaitForTimeout(1);
  putValue(CAPL_TIME,timeNow());
  while(1)
  {
    if(getValue(StateMachine_TIME)!=State_TIME_)
    {
      getValue(StateMachine_String,State_String_);
      break;
    }
    testWaitForTimeout(1);
  }
  k1=strstr_off(State_String_,0,"@");
  k2=strstr_off(State_String_,k1+1,"@");
  if(k1>0&&k2>0)
  {
    substr_cpy(Dbuf1,State_String_,0,k1,elCount(Dbuf1));
    substr_cpy(Dbuf2,State_String_,k1+1,k2-k1-1,elCount(Dbuf2));
    write("Describ==Test_LINDLC==:%s",Dbuf2);
    Re=atol(Dbuf1);
    strncpy (Describ,Dbuf2,elcount(Describ));
  }
  else Re=-1;
  State_TIME_=getValue(StateMachine_TIME);
  return Re;
}

