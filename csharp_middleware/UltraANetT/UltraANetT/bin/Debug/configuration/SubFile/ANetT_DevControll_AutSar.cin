/*----- 测试上电/下电初始化控制 -----*/
void TestInit(int mode)  //测试初始化上电
{
  sysvar::VTS::M1_VT7001.SetInterconnectionMode(1);//VT7001电源模式设置SUP1
//  POW_CurrOutSetup(5);testWaitForTimeout(500);
//  If(DUT.SystemType==1)
//  {
//    POW_VoltOutSetup(24);testWaitForTimeout(500);
//  }
//  else
//  {
//   POW_VoltOutSetup(12);testWaitForTimeout(500);
//  }
  POW_OutputSwitch(1); 
  testWaitForTimeout(100);  //用于等效电源启动过程的等待延时
  
  if(mode==0)
  {
   CASE_TJ_CAN1(0); 
  }
  if(mode==1)
  {
   CASE_TJ_CAN1(1);  
  }
  if (DUT.TerminalR ==1)
  {
   CAN_120_1(1);
  }
  if (DUT.TerminalR ==0)
  {
   CAN_120_1(1);
   CAN_120_2(1);
  }
  KL_on(); 
  Gnd_on();

 }

void TestInit_OnlyKL30(int mode)  //测试初始化上电
{
  sysvar::VTS::M1_VT7001.SetInterconnectionMode(1);//VT7001电源模式设置SUP1
//  POW_CurrOutSetup(5);testWaitForTimeout(500);
//  If(DUT.SystemType==1)
//  {
//    POW_VoltOutSetup(24);testWaitForTimeout(500);
//  }
//  else
//  {
//   POW_VoltOutSetup(12);testWaitForTimeout(500);
//  }
  POW_OutputSwitch(1);
  testWaitForTimeout(100);  //用于等效电源启动过程的等待延时  

  if(mode==0)
  {
   CASE_TJ_CAN1(0); 
  }
  if(mode==1)
  {
   CASE_TJ_CAN1(1);  
  }
  if (DUT.TerminalR ==1)
  {
   CAN_120_1(1);
  }
  if (DUT.TerminalR ==0)
  {
   CAN_120_1(1);
   CAN_120_2(1);
  }
  K30_on();
  Gnd_on();
  
  writetolog("----------测试初始化上电----------");
}

TestEndReset()  //测试结束下电
{
//  POW_OutputSwitch(0);
  KL_off();
  Gnd_off();
  MasterBOBControl(0 , 64, 0, MasteBOB.qword(0));
  write("----------测试结束下电----------");
  writetolog("----------测试结束下电----------");
  testWaitForTimeout(T_KL_OFF+1000);
}

/*----- VT7001控制 -----*/
Gnd_on()
{
  ErrorFlag++;
  MasterBOBControl(6 , 1, ErrorFlag%2, MasteBOB.qword(0));
  Testwaitfortimeout(5);   //继电器动作延时时间
  @sysvar::VTS::M2_Ch3::Relay = 1;
  writetolog("----------上电源地----------");
  //RefValueToSystemVar("上电源地"); 
}

Gnd_off()
{
  ErrorFlag++;
  MasterBOBControl(6 , 1, ErrorFlag%2, MasteBOB.qword(0));
  Testwaitfortimeout(5);   //继电器动作延时时间
  @sysvar::VTS::M2_Ch3::Relay = 0;
  writetolog("----------下电源地----------");
  //RefValueToSystemVar("下电源地"); 
}

K30_on()
{	
  ErrorFlag++;
  MasterBOBControl(6 , 1, ErrorFlag%2, MasteBOB.qword(0));
  Testwaitfortimeout(5);   //继电器动作延时时间
  @sysvar::VTS::M1_Out1::Active = 1;
  writetolog("----------KL30上电----------");
  //RefValueToSystemVar("KL30上电"); 
}

K30_off()
{
  ErrorFlag++;
  MasterBOBControl(6 , 1, ErrorFlag%2, MasteBOB.qword(0));
  Testwaitfortimeout(5);   //继电器动作延时时间
  @sysvar::VTS::M1_Out1::Active = 0;
  writetolog("----------KL30下电----------");
  //RefValueToSystemVar("KL30下电"); 
}

K15_on ()
{  
  ErrorFlag++;
  MasterBOBControl(6 , 1, ErrorFlag%2, MasteBOB.qword(0));
  Testwaitfortimeout(5);   //继电器动作延时时间
  @sysvar::VTS::M1_Out2::Active = 1;
  writetolog("----------KL15上电----------");
  RefValueToSystemVar("KL15上电"); 
  if(strncmp(DUT.Name,"BCM",elCount(DUT.Name))==0)
  {
    writetolog("----------开始发送0x162----------");
    setTimer(PowerModeOn_Timer,20);
  }
}

K15_off ()
{
  ErrorFlag++;
  MasterBOBControl(6 , 1, ErrorFlag%2, MasteBOB.qword(0));
  Testwaitfortimeout(5);   //继电器动作延时时间
  @sysvar::VTS::M1_Out2::Active = 0;
  writetolog("----------KL15下电----------");
  //RefValueToSystemVar("KL15下电");
  if(strncmp(DUT.Name,"BCM",elCount(DUT.Name))==0)
  {
  cancelTimer(PowerModeOn_Timer); 
  writetolog("----------停止发送0x162----------");
  }
}

KL_off()
{
  ErrorFlag++;
  MasterBOBControl(6 , 1, 1, MasteBOB.qword(0));
  //MasterBOBControl(6 , 1, ErrorFlag%2, MasteBOB.qword(0));
  Testwaitfortimeout(5);   //继电器动作延时时间
  @sysvar::VTS::M1_Out1::Active = 0;
  @sysvar::VTS::M1_Out2::Active = 0;
  @sysvar::VTS::M2_Ch1::Relay = 0;
  @sysvar::VTS::M2_Ch2::Relay = 0;
  writetolog("----------KL下电----------");
  //RefValueToSystemVar("KL下电");
}

KL_on()
{
  ErrorFlag++;
  MasterBOBControl(6 , 1, 0, MasteBOB.qword(0));
  //MasterBOBControl(6 , 1, ErrorFlag%2, MasteBOB.qword(0));
  Testwaitfortimeout(5);   //继电器动作延时时间
  write("----------KL上电----------");
  @sysvar::VTS::M1_Out1::Active = 1;
  @sysvar::VTS::M1_Out2::Active = 1;
  @sysvar::VTS::M2_Ch1::Relay = 1;
  @sysvar::VTS::M2_Ch2::Relay = 1;
  writetolog("----------KL上电----------");
  //RefValueToSystemVar("KL上电");
}

Ground_Offset(int State)
{
   CASE_TJ_CAN1(0); 

  if(DUT.TerminalR ==1)
  {
   CAN_120_1(1);
  }
  if (DUT.TerminalR ==0)
  {
   CAN_120_1(1);
   CAN_120_2(1);
  }
  //@sysvar::VTS::M2_Ch1::RelayOpenHigh = 0;
  //@sysvar::VTS::M2_Ch1::RelayOpenLow = 0;     
  if(State==1)
  {
    sysvar::VTS::M1_VT7001.SetInterconnectionMode(9);
    @sysvar::VTS::M1_Sup2::ReversePolarity = 1; //接入H&H电源  
    MasterBOBControl(31 , 1, 1, MasteBOB.qword(0));
    Testwaitfortimeout(5);   //继电器动作延时时间
    POW_Ambi_Initial();
    POW_Ambi_CurrOutSetup(2);
    POW_Ambi_VoltOutSetup(0);
    POW_Ambi_OutputSwitch(1);
    Testwaitfortimeout(50);
    KL_on();
    Gnd_on();    
//    POW_CurrOutSetup(5);testWaitForTimeout(500);
//    If(DUT.SystemType==1)
//    {
//      POW_VoltOutSetup(24);testWaitForTimeout(500);
//    }
//    else
//    {
//     POW_VoltOutSetup(12);testWaitForTimeout(500);
//    }    //必须先配置好地偏移电路，再供电 
    POW_OutputSwitch(1);
    writeToLog("=======开始地偏=======");
    //RefValueToSystemVar("置为地偏移电路"); 
  }
  if(State==0)
  {
    sysvar::VTS::M1_VT7001.SetInterconnectionMode(1);
    @sysvar::VTS::M1_Sup2::ReversePolarity = 0;//断开H&H电源
    MasterBOBControl(31 , 1, 0, MasteBOB.qword(0));
    Testwaitfortimeout(5);   //继电器动作延时时间
    writeToLog("=======地偏恢复=======");
    //RefValueToSystemVar("取消地偏移电路"); 
  }
}

/*----- VT7900控制 -----*/
CANH_off(int State)
{
  if(State==1)
  {
    ErrorFlag++;
    @sysvar::VTS::M2_Ch19::Relay = 0;
    MasterBOBControl(6 , 1, ErrorFlag%2, MasteBOB.qword(0));
    Testwaitfortimeout(5);
    writeToLog("=======CANH断路=======");
    //RefValueToSystemVar("CANH断路"); 
  }
  if(State==0)
  {
    ErrorFlag++;
    @sysvar::VTS::M2_Ch19::Relay = 1;
    MasterBOBControl(6 , 1, ErrorFlag%2, MasteBOB.qword(0));
    //Testwaitfortimeout(300);
    writeToLog("=======CANH断路恢复分析记录文件=======");
    //RefValueToSystemVar("CANH断路恢复"); 
  }
}

