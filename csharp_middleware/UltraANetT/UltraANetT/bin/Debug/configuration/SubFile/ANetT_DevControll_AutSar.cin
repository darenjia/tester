CANHL_ShortToPower(int State)
{
  if(State==1)
  {
    ErrorFlag++;
    MasterBOBControl(6 , 1, ErrorFlag%2, MasteBOB.qword(0));
    testWaitForTimeout(2);
    MasterBOBControl(5 , 1, 1, MasteBOB.qword(0));
    MasteBOB.qword(0)=message_bit_set(0, 1, 1, MasteBOB.qword(0));
    MasterBOBControl(8 , 1, 1, MasteBOB.qword(0));
    Testwaitfortimeout(5);
    writeToLog("========CANHL短电======");
    //RefValueToSystemVar("CANHL短电"); 
  }
  if(State==0)
  {
    ErrorFlag++;
    MasterBOBControl(6 , 1, ErrorFlag%2, MasteBOB.qword(0));
    testWaitForTimeout(2);
    MasterBOBControl(5 , 1, 1, MasteBOB.qword(0));
    MasteBOB.qword(0)=message_bit_set(0, 1, 0, MasteBOB.qword(0));
    MasterBOBControl(8 , 1, 0, MasteBOB.qword(0));
    //Testwaitfortimeout(300);
    writeToLog("=======CANHL短电恢复分析记录文件=======");
    //RefValueToSystemVar("CANHL短电恢复"); 
  }
}

