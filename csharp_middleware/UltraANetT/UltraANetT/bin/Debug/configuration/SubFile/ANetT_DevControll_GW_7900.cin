/*----- 测试上电/下电初始化控制 -----*/
void TestInit()  //测试初始化上电
{
  sysvar::VTS::M1_VT7001.SetInterconnectionMode(1);//VT7001电源模式设置SUP1
  KL_on(); 
  Gnd_on();
  
  //CASE接CAN1
  sysSetVariableInt(sysvar::VTS::M2_NewConfig::PCA9506_Std_4,message_bit_set(sysvar::VTS::M2_NewConfig::PCA9506_Std_4,5,1,1));
  testWaitForTimeout(1000);
  sysSetVariableInt(sysvar::VTS::M2_NewConfig::PCA9506_Std_4,message_bit_set(sysvar::VTS::M2_NewConfig::PCA9506_Std_4,6,1,1));
 // @sysvar::VTS::M3_Ch5::Relay = 1;
 // @sysvar::VTS::M3_Ch6::Relay = 1;
  
  @sysvar::VTS::M3_Ch19::Relay = 1;
  @sysvar::VTS::M3_Ch20::Relay = 1;
//  CAN_120_1(1);
  //设置电源输出
  POW_CurrOutSetup(5);testWaitForTimeout(500);
  if(DUT.SystemType==0)
  {
    POW_VoltOutSetup(12);testWaitForTimeout(1000);
  }
  if(DUT.SystemType==1)
  {
    POW_VoltOutSetup(24);testWaitForTimeout(1000);
  }
  POW_OutputSwitch(1);testWaitForTimeout(2000);
  write("测试初始化上电");
  writetolog("----------测试初始化上电----------");
}

