TestEndReset()  //测试结束下电
{
  KL_off();
  Gnd_off();
  writetolog("----------测试结束下电----------");
  testWaitForTimeout(3000);
}

/*----- VT7001控制 -----*/
Gnd_on()
{
  ErrorFlag++;
  sysSetVariableInt(sysvar::VTS::M2_NewConfig::PCA9506_Std_2,message_bit_set(sysvar::VTS::M2_NewConfig::PCA9506_Std_2,1,1,ErrorFlag%2));
  @sysvar::VTS::M3_Ch3::Relay = 1; 
  writetolog("----------上电源地----------");
  //RefValueToSystemVar("上电源地"); 
}

Gnd_off()
{
  ErrorFlag++;
  sysSetVariableInt(sysvar::VTS::M2_NewConfig::PCA9506_Std_2,message_bit_set(sysvar::VTS::M2_NewConfig::PCA9506_Std_2,1,1,ErrorFlag%2));
  @sysvar::VTS::M3_Ch3::Relay = 0;
  writetolog("----------下电源地----------");
  //RefValueToSystemVar("下电源地"); 
}

K30_on()
{	
  ErrorFlag++;
  sysSetVariableInt(sysvar::VTS::M2_NewConfig::PCA9506_Std_2,message_bit_set(sysvar::VTS::M2_NewConfig::PCA9506_Std_2,1,1,ErrorFlag%2));
  @sysvar::VTS::M1_Out1::Active = 1;
  writetolog("----------KL30上电----------");
  RefValueToSystemVar("KL30上电"); 
}

K30_off()
{
  ErrorFlag++;
  sysSetVariableInt(sysvar::VTS::M2_NewConfig::PCA9506_Std_2,message_bit_set(sysvar::VTS::M2_NewConfig::PCA9506_Std_2,1,1,ErrorFlag%2));
  @sysvar::VTS::M1_Out1::Active = 0;
  writetolog("----------KL30下电----------");
  RefValueToSystemVar("KL30下电"); 
}

K15_on ()
{  
  ErrorFlag++;
  sysSetVariableInt(sysvar::VTS::M2_NewConfig::PCA9506_Std_2,message_bit_set(sysvar::VTS::M2_NewConfig::PCA9506_Std_2,1,1,ErrorFlag%2));
  @sysvar::VTS::M1_Out2::Active = 1;
  writetolog("----------KL15上电----------");
  RefValueToSystemVar("KL15上电"); 
}

K15_off ()
{
  ErrorFlag++;
  sysSetVariableInt(sysvar::VTS::M2_NewConfig::PCA9506_Std_2,message_bit_set(sysvar::VTS::M2_NewConfig::PCA9506_Std_2,1,1,ErrorFlag%2));
  @sysvar::VTS::M1_Out2::Active = 0;
  writetolog("----------KL15下电----------");
  RefValueToSystemVar("KL15下电"); 
}

KL_off()
{
  ErrorFlag++;
  sysSetVariableInt(sysvar::VTS::M2_NewConfig::PCA9506_Std_2,message_bit_set(sysvar::VTS::M2_NewConfig::PCA9506_Std_2,1,1,ErrorFlag%2));
  @sysvar::VTS::M1_Out1::Active = 0;
  @sysvar::VTS::M1_Out2::Active = 0;
  @sysvar::VTS::M3_Ch1::Relay = 0;
  @sysvar::VTS::M3_Ch2::Relay = 0;
  writetolog("----------KL下电----------");
  RefValueToSystemVar("KL下电"); 
}

KL_on()
{
  ErrorFlag++;
  sysSetVariableInt(sysvar::VTS::M2_NewConfig::PCA9506_Std_2,message_bit_set(sysvar::VTS::M2_NewConfig::PCA9506_Std_2,1,1,ErrorFlag%2));
  @sysvar::VTS::M1_Out1::Active = 1;
  @sysvar::VTS::M1_Out2::Active = 1;
  @sysvar::VTS::M3_Ch1::Relay = 1;
  @sysvar::VTS::M3_Ch2::Relay = 1;
  writetolog("----------KL上电----------");
  //RefValueToSystemVar("KL上电"); 
}

