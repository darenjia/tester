long ANetT_Test_J1939_StuffBit(char Path[],long ByteOrder,long Channel,dword StandardID[],long signal_N[],long startbit[][],long length[][],char Describ[])
{

  char Sbuf[10000];
  char Dbuf1[10000];
  char Dbuf2[10000];
  char Dbuf3[10000];
  char StandardIDTemp[100];
  char signal_NTemp[100];
  char startbitTemp[100];
  char lengthTemp[100];
  char ChannelTemp[10];
  char ByteOrderTemp[10];
  long Re=0;
  int i=0;
  int j=0;
  int p=0;
  int m=0;
  int n=0;
  int q=0;  
  char absPath[1000];
  getAbsFilePath(Path,absPath,1000);
  strncpy(Sbuf,"",elCount(Sbuf));
  strncat(Sbuf,"ANetT_Test_J1939_StuffBit@",elCount(Sbuf));
  strncat(Sbuf,absPath,elCount(Sbuf));
  strncat(Sbuf,"@",elCount(Sbuf));
  ltoa(ByteOrder,ByteOrderTemp,10);
  strncat(Sbuf,ByteOrderTemp,elCount(Sbuf));
  strncat(Sbuf,"@",elCount(Sbuf));
  ltoa(Channel,ChannelTemp,10);
  strncat(Sbuf,ChannelTemp,elCount(Sbuf));
  strncat(Sbuf,"@",elCount(Sbuf));
  for(i=0;i<500;i++)
  {
    if(StandardID[i]=='\0') break;
    ltoa(StandardID[i],StandardIDTemp,16);
    strncat(Sbuf,StandardIDTemp,elCount(Sbuf));
    strncat(Sbuf,"#",elCount(Sbuf));
  }
  strncat(Sbuf,"@",elCount(Sbuf));
  for(j=0;j<500;j++)
  {
    if(signal_N[j]=='\0') break;
    ltoa(signal_N[j],signal_NTemp,10);
    strncat(Sbuf,signal_NTemp,elCount(Sbuf));
    strncat(Sbuf,"#",elCount(Sbuf));
  }
  strncat(Sbuf,"@",elCount(Sbuf));
  for(m=0;m<100;m++)
  {
    for(n=0;n<signal_N[m];n++)
    {
     // if(startbit[m][n]=='\0') break;
      ltoa(startbit[m][n],startbitTemp,10);
      strncat(Sbuf,startbitTemp,elCount(Sbuf));
      strncat(Sbuf,"#",elCount(Sbuf));
    }
  }
  strncat(Sbuf,"@",elCount(Sbuf));
  for(p=0;p<100;p++)
  {
    for(q=0;q<500;q++)
    {
      if(length[p][q]=='\0') break;
      ltoa(length[p][q],lengthTemp,10);
      strncat(Sbuf,lengthTemp,elCount(Sbuf));
      strncat(Sbuf,"#",elCount(Sbuf));
    }
  }
  strncat(Sbuf,"@",elCount(Sbuf));
  putValue(CAPL_String,Sbuf);
  testWaitForTimeout(1);
  putValue(CAPL_TIME,timeNow());
  while(1)
  {
    if(getValue(StateMachine_TIME)!=State_TIME_)
    {
      getValue(StateMachine_String,State_String_);
      break;
    }
    testWaitForTimeout(1);
  }
  k1=strstr_off(State_String_,0,"@");
  k2=strstr_off(State_String_,k1+1,"@");
  if(k1>0&&k2>0)
  {
    substr_cpy(Dbuf1,State_String_,0,k1,elCount(Dbuf1));
    substr_cpy(Dbuf2,State_String_,k1+1,k2-k1-1,elCount(Dbuf2));
    Re=atol(Dbuf1);
    strncpy (Describ,Dbuf2,elcount(Describ));
  }
  else Re=-1;
  State_TIME_=getValue(StateMachine_TIME);
  return Re;}

long DeleteIDArray(dword ID[],dword deleteID[])
{
  char Sbuf[1000];
  char Dbuf1[1000];
  char Dbuf2[1000];
  char Dbuf3[1000];
  char ChannelTemp[10];
  char IDTemp[10];
  char deleteIDTemp[10];
  long Re=0;
  int i=0;
  int j=0;
  strncpy(Sbuf,"",elCount(Sbuf));
  strncat(Sbuf,"DeleteIDArray@",elCount(Sbuf));
  for(i=0;i<500;i++)
  {
    if(ID[i]=='\0') break;
    ltoa(ID[i],IDTemp,16);
    strncat(Sbuf,IDTemp,elCount(Sbuf));
    strncat(Sbuf,"#",elCount(Sbuf));
  }
  strncat(Sbuf,"@",elCount(Sbuf));
  for(i=0;i<500;i++)
  {
    if(deleteID[i]=='\0' && i>=1) break;
    ltoa(deleteID[i],deleteIDTemp,16);
    strncat(Sbuf,deleteIDTemp,elCount(Sbuf));
    strncat(Sbuf,"#",elCount(Sbuf));
  }
  strncat(Sbuf,"@",elCount(Sbuf));
//  write("Sbuf===========%s",Sbuf);
  
  putValue(CAPL_String,Sbuf);
  testWaitForTimeout(1);
  putValue(CAPL_TIME,timeNow());
  while(1)
  {
    if(getValue(StateMachine_TIME)!=State_TIME_)
    {
      getValue(StateMachine_String,State_String_);
      break;
    }
    testWaitForTimeout(1);
  }
  k1=strstr_off(State_String_,0,"@");
  k2=strstr_off(State_String_,k1+1,"@");
//  write("State_String_===========%s",State_String_);
  if(k1>0&&k2>0)
  {
    for(i=0;i<500;i++)
    {
      if(ID[i]=='\0') break;
      ID[i]=0;
    } 
    //先删除ID所有元素
    substr_cpy(Dbuf1,State_String_,0,k1,elCount(Dbuf1));
    substr_cpy(Dbuf2,State_String_,k1+1,k2-k1-1,elCount(Dbuf2));
    Re=atol(Dbuf1);
    k4=-1;
    for(i=0;i<500;i++)
    {
      if(strstr_off(Dbuf2,k4+1,"#")<=0) break;
      for(j=0;j<10;j++)
      {
        IDTemp[j]=0;
      }
      substr_cpy(IDTemp,Dbuf2,k4+1,strstr_off(Dbuf2,k4+1,"#")-k4-1,elCount(IDTemp));
      strtoul(IDTemp,ID[i]);
      k4=strstr_off(Dbuf2,k4+1,"#");
    }
  }
  else Re=-1;
  State_TIME_=getValue(StateMachine_TIME);
  return Re;
}

long Delete_RecordFile(char Path[])
{
  char Sbuf[1000];
  char Dbuf[1000];
  long Re=0;
  char absPath[1000];
  getAbsFilePath(Path,absPath,1000);
  write("DeleteFile====%s",absPath);
  strncpy(Sbuf,"",elCount(Sbuf));
  strncat(Sbuf,"Delete_RecordFile@",elCount(Sbuf));
  strncat(Sbuf,absPath,elCount(Sbuf));
  strncat(Sbuf,"@",elCount(Sbuf));
  putValue(CAPL_String,Sbuf);
  testWaitForTimeout(1);
  putValue(CAPL_TIME,timeNow());
  while(1)
  {
    if(getValue(StateMachine_TIME)!=State_TIME_)
    {
      getValue(StateMachine_String,State_String_);
      break;
    }
    testWaitForTimeout(1);
  }
  k1=strstr_off(State_String_,0,"@");
  if(k1>0)
  {
    substr_cpy(Dbuf,State_String_,0,k1,elCount(Dbuf));
    Re=atol(Dbuf);
  }
  else Re=-1;
  State_TIME_=getValue(StateMachine_TIME);
  return Re;
}

