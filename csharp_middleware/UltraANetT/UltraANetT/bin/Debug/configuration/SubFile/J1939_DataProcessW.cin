long ANetT_Database_J1939_MsgAll(char DUTName[], dword ID[],long signal_N[],long startbit[][],long length[][],long method[][])
{
  char Sbuf[1000];
  char Dbuf1[2000];
  char Dbuf2[2000];
  char Dbuf3[2000];
  char Dbuf4[2000];
  char Dbuf5[2000];
  char Dbuf6[2000];
  char IDTemp[10];
  char signal_NTemp[10];
  char startbitTemp1[500];
  char startbitTemp2[10];
  char lengthTemp1[500];
  char lengthTemp2[10];
  char methodTemp1[500];
  char methodTemp2[10];
  long Re=0;
  int i=0;
  int j=0;
  int k=0;
  strncpy(Sbuf,"",elCount(Sbuf));
  strncat(Sbuf,"ANetT_Database_J1939_MsgAll@",elCount(Sbuf));
  strncat(Sbuf,DUTName,elCount(Sbuf));
  strncat(Sbuf,"@",elCount(Sbuf));
  write("Sbuf==MsgAll==%s",Sbuf);
  putValue(CAPL_String,Sbuf);
  testWaitForTimeout(1);
  putValue(CAPL_TIME,timeNow());
  while(1)
  {
    if(getValue(StateMachine_TIME)!=State_TIME_)
    {
      getValue(StateMachine_String,State_String_);
      break;
    }
    testWaitForTimeout(1);
  }
  k1=strstr_off(State_String_,0,"@");
  k2=strstr_off(State_String_,k1+1,"@");
  k3=strstr_off(State_String_,k2+1,"@");
  k4=strstr_off(State_String_,k3+1,"@");
  k5=strstr_off(State_String_,k4+1,"@");
  k6=strstr_off(State_String_,k5+1,"@");
  if(k1>0&&k2>0&&k3>0&&k4>0&&k5>0&&k6>0)
  {
    substr_cpy(Dbuf1,State_String_,0,k1,elCount(Dbuf1));
    substr_cpy(Dbuf2,State_String_,k1+1,k2-k1-1,elCount(Dbuf2));
    substr_cpy(Dbuf3,State_String_,k2+1,k3-k2-1,elCount(Dbuf3));
    substr_cpy(Dbuf4,State_String_,k3+1,k4-k3-1,elCount(Dbuf4));
    substr_cpy(Dbuf5,State_String_,k4+1,k5-k4-1,elCount(Dbuf5));
    substr_cpy(Dbuf6,State_String_,k5+1,k6-k5-1,elCount(Dbuf6));
    write("ID====%s",Dbuf2);
    write("信号个数====%s",Dbuf3);
    write("STB====%s",Dbuf4);
    write("length====%s",Dbuf5);
    write("发送方式====%s",Dbuf6);
    Re=atol(Dbuf1);
    k7=-1;
    for(i=0;i<500;i++)
    {
      if(strstr_off(Dbuf2,k7+1,"#")<=0) break;
      for(j=0;j<10;j++)
      {
        IDTemp[j]=0;
      }
      substr_cpy(IDTemp,Dbuf2,k7+1,strstr_off(Dbuf2,k7+1,"#")-k7-1,elCount(IDTemp));
      strtoul(IDTemp,ID[i]);
      k7=strstr_off(Dbuf2,k7+1,"#");
    }
    k8=-1;
    for(i=0;i<500;i++)
    {
      if(strstr_off(Dbuf3,k8+1,"#")<=0) break;
      for(j=0;j<10;j++)
      {
        signal_NTemp[j]=0;
      }
      substr_cpy(signal_NTemp,Dbuf3,k8+1,strstr_off(Dbuf3,k8+1,"#")-k8-1,elCount(signal_NTemp));
      strtol(signal_NTemp,signal_N[i]);
      k8=strstr_off(Dbuf3,k8+1,"#");
    }
    k9=-1;
    for(i=0;i<500;i++)
    {
      if(strstr_off(Dbuf4,k9+1,"#")<=0) break;
      for(j=0;j<500;j++)
      {
        startbitTemp1[j]=0;
      }
      substr_cpy(startbitTemp1,Dbuf4,k9+1,strstr_off(Dbuf4,k9+1,"#")-k9-1,elCount(startbitTemp1));
      k10=-1;
      for(k=0;k<100;k++)
      {
        if(strstr_off(startbitTemp1,k10+1,"$")<=0) break;
        for(j=0;j<10;j++)
        {
          startbitTemp2[j]=0;
        }
        substr_cpy(startbitTemp2,startbitTemp1,k10+1,strstr_off(startbitTemp1,k10+1,"$")-k10-1,elCount(startbitTemp2));
        strtol(startbitTemp2,startbit[i][k]);
        k10=strstr_off(startbitTemp1,k10+1,"$");
      }
      k9=strstr_off(Dbuf4,k9+1,"#");
    }
    k11=-1;
    for(i=0;i<500;i++)
    {
      if(strstr_off(Dbuf5,k11+1,"#")<=0) break;
      for(j=0;j<500;j++)
      {
        lengthTemp1[j]=0;
      }
      substr_cpy(lengthTemp1,Dbuf5,k11+1,strstr_off(Dbuf5,k11+1,"#")-k11-1,elCount(lengthTemp1));
      k12=-1;
      for(k=0;k<100;k++)
      {
        if(strstr_off(lengthTemp1,k12+1,"$")<=0) break;
        for(j=0;j<10;j++)
        {
          lengthTemp2[j]=0;
        }
        substr_cpy(lengthTemp2,lengthTemp1,k12+1,strstr_off(lengthTemp1,k12+1,"$")-k12-1,elCount(lengthTemp2));
        strtol(lengthTemp2,length[i][k]);
        k12=strstr_off(lengthTemp1,k12+1,"$");
      }
      k11=strstr_off(Dbuf5,k11+1,"#");
    }
    k13=-1;
    for(i=0;i<500;i++)
    {
      if(strstr_off(Dbuf6,k13+1,"#")<=0) break;
      for(j=0;j<500;j++)
      {
        methodTemp1[j]=0;
      }
      substr_cpy(methodTemp1,Dbuf6,k13+1,strstr_off(Dbuf6,k13+1,"#")-k13-1,elCount(methodTemp1));
      k14=-1;
      for(k=0;k<100;k++)
      {
        if(strstr_off(methodTemp1,k14+1,"$")<=0) break;
        for(j=0;j<10;j++)
        {
          methodTemp2[j]=0;
        }
        substr_cpy(methodTemp2,methodTemp1,k14+1,strstr_off(methodTemp1,k14+1,"$")-k14-1,elCount(methodTemp2));
        strtol(methodTemp2,method[i][k]);
        k14=strstr_off(methodTemp1,k14+1,"$");
      }
      k13=strstr_off(Dbuf6,k13+1,"#");
    }
  }
  else Re=-1;
  State_TIME_=getValue(StateMachine_TIME);
  return Re;
}

