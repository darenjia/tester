/*@!Encoding:936*/
long ANetT_Database_J1939_File(char Path[])
{
  char Sbuf[1000];
  char Dbuf[1000];
  long Re=0;
  char absPath[1000];
  getAbsFilePath(Path,absPath,1000);
  strncpy(Sbuf,"",elCount(Sbuf));
  strncat(Sbuf,"ANetT_Database_J1939_File@",elCount(Sbuf));
  strncat(Sbuf,absPath,elCount(Sbuf));
  strncat(Sbuf,"@",elCount(Sbuf));
  write("Sbuf====%s",Sbuf);
  putValue(CAPL_String,Sbuf);
  testWaitForTimeout(1);
  putValue(CAPL_TIME,timeNow());
  while(1)
  {
    if(getValue(StateMachine_TIME)!=State_TIME_)
    {
      getValue(StateMachine_String,State_String_);
      write("State_String_===%s",State_String_);
      break;
    }
    testWaitForTimeout(1);
  }
  k1=strstr_off(State_String_,0,"@");
  if(k1>0)
  {
    substr_cpy(Dbuf,State_String_,0,k1,elCount(Dbuf));
    Re=atol(Dbuf);
    write("Re===%d",Re);
  }
  else Re=-1;
  State_TIME_=getValue(StateMachine_TIME);
  return Re;
}

long ANetT_Database_J1939_TXID(char DUTName[], dword ID[])
{
  char Sbuf[1000];
  char Dbuf1[1000];
  char Dbuf2[1000];
  char IDTemp[10];
  long Re=0;
  int i=0;
  int j=0;
  strncpy(Sbuf,"",elCount(Sbuf));
  strncat(Sbuf,"ANetT_Database_J1939_TXID@",elCount(Sbuf));
  strncat(Sbuf,DUTName,elCount(Sbuf));
  strncat(Sbuf,"@",elCount(Sbuf));
  write("Sbuf==TXID==%s",Sbuf);
  putValue(CAPL_String,Sbuf);
  testWaitForTimeout(1);
  putValue(CAPL_TIME,timeNow());
  while(1)
  {
    if(getValue(StateMachine_TIME)!=State_TIME_)
    {
      getValue(StateMachine_String,State_String_);
      break;
    }
    testWaitForTimeout(1);
  }
  k1=strstr_off(State_String_,0,"@");
  k2=strstr_off(State_String_,k1+1,"@");
  if(k1>0&&k2>0)
  {
    substr_cpy(Dbuf1,State_String_,0,k1,elCount(Dbuf1));
    substr_cpy(Dbuf2,State_String_,k1+1,k2-k1-1,elCount(Dbuf2));
    Re=atol(Dbuf1);
    k3=-1;
    write("ID====%s",Dbuf2);
    for(i=0;i<500;i++)
    {
      if(strstr_off(Dbuf2,k3+1,"#")<=0) break;
      for(j=0;j<10;j++)
      {
        IDTemp[j]=0;
      }
      substr_cpy(IDTemp,Dbuf2,k3+1,strstr_off(Dbuf2,k3+1,"#")-k3-1,elCount(IDTemp));
      strtoul(IDTemp,ID[i]);
      k3=strstr_off(Dbuf2,k3+1,"#");
    }
  }
  else Re=-1;
  State_TIME_=getValue(StateMachine_TIME);
  return Re;
}

