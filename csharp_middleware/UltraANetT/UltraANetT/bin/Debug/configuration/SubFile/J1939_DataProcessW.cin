long ANetT_Database_J1939_IDCycletimeDLC(dword ID[],long DLC[],long Cycletime[])
{
  char Sbuf[1000];
  char Dbuf1[1000];
  char Dbuf2[1000];
  char Dbuf3[1000];
  char IDTemp[10];
  char DLCTemp[10];
  char CycleTemp[10];
  long Re=0;
  int i=0;
  int j=0;
  strncpy(Sbuf,"",elCount(Sbuf));
  strncat(Sbuf,"ANetT_Database_J1939_IDCycletimeDLC@",elCount(Sbuf));
  for(i=0;i<500;i++)
  {
    if(ID[i]=='\0') break;
    ltoa(ID[i],IDTemp,16);
    strncat(Sbuf,IDTemp,elCount(Sbuf));
    strncat(Sbuf,"#",elCount(Sbuf));
  }
  strncat(Sbuf,"@",elCount(Sbuf));
  write("Sbuf==IDCycletimeDLC==%s",Sbuf);
  putValue(CAPL_String,Sbuf);
  testWaitForTimeout(1);
  putValue(CAPL_TIME,timeNow());
  while(1)
  {
    if(getValue(StateMachine_TIME)!=State_TIME_)
    {
      getValue(StateMachine_String,State_String_);
      break;
    }
    testWaitForTimeout(1);
  }
  k1=strstr_off(State_String_,0,"@");
  k2=strstr_off(State_String_,k1+1,"@");
  k3=strstr_off(State_String_,k2+1,"@");
  if(k1>0&&k2>0&&k3>0)
  {
    substr_cpy(Dbuf1,State_String_,0,k1,elCount(Dbuf1));
    substr_cpy(Dbuf2,State_String_,k1+1,k2-k1-1,elCount(Dbuf2));
    substr_cpy(Dbuf3,State_String_,k2+1,k3-k2-1,elCount(Dbuf3));
    write("DLC====%s",Dbuf2);
    write("Cycletime====%s",Dbuf3);
    Re=atol(Dbuf1);
    k4=-1;
    for(i=0;i<500;i++)
    {
      if(strstr_off(Dbuf2,k4+1,"#")<=0) break;
      for(j=0;j<10;j++)
      {
        DLCTemp[j]=0;
      }
      substr_cpy(DLCTemp,Dbuf2,k4+1,strstr_off(Dbuf2,k4+1,"#")-k4-1,elCount(DLCTemp));
      strtol(DLCTemp,DLC[i]);
      k4=strstr_off(Dbuf2,k4+1,"#");
    }
    k5=-1;
    for(i=0;i<500;i++)
    {
      if(strstr_off(Dbuf3,k5+1,"#")<=0) break;
      for(j=0;j<10;j++)
      {
        CycleTemp[j]=0;
      }
      substr_cpy(CycleTemp,Dbuf3,k5+1,strstr_off(Dbuf3,k5+1,"#")-k5-1,elCount(CycleTemp));
      strtol(CycleTemp,Cycletime[i]);
      k5=strstr_off(Dbuf3,k5+1,"#");
    }
  }
  else Re=-1;
  State_TIME_=getValue(StateMachine_TIME);
  return Re;
}

