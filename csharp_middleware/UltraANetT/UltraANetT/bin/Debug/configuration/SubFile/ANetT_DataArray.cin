}

void DisturbID_P0P1(dword DisturbID)
{
  dword byteIndices[2];
  dword bitIndices[2];
  dword numberOfDisturbedBits[2];
  dword levels[2];
  dword arrSize;
  dword byte2;
  
  byteIndices[0]=1;byteIndices[1]=1;
  bitIndices[0]=6;bitIndices[1]=7;
  numberOfDisturbedBits[0]=1;numberOfDisturbedBits[1]=1;
  levels[0]=1;levels[1]=1;
  arrSize=2;
  write("111111111=====%x",DisturbID);
  
  byte2=DisturbID^0xFF;
  byte2=byte2>>6; 
  write("-----1=====%x",byte2);
  levels[0]=byte2&0x01;
  levels[1]=byte2>>1;
  levels[1]=levels[1]&0x01;
  write("000=====%x",levels[0]);write("1111=====%x",levels[1]);
  
  linInvertMultipleHeaderBits(byteIndices, bitIndices, numberOfDisturbedBits, levels,arrSize); //,1,0x18,0 //1为干扰次数，0x18为干扰之前的ID，0为等待几个报文头
//    linInvertMultipleHeaderBits(1,1,1,4,0);
  }

void Disturb_Checksum_DLC(dword DisturbID,byte DisturbID_DLC,byte byte0,int flag) //flag==1 Checksum干扰  flag==2 数据场干扰  flag==3 数据场结束位干扰 
{
  
  dword byteIndices[8]={8,8,8,8,8,8,8,8};
  dword bitIndices[8]={0,1,2,3,4,5,6,7};
  dword numberOfDisturbedBits[8]={1,1,1,1,1,1,1,1};
  byte  levels[8]={0,0,0,0,0,0,0,0};
  dword arrSize=8; 
  int  i;
  if(flag==1)
   // linInvertRespBit (DisturbID, DisturbID_DLC,  7);  
  linDisturbRespWithBitStream(DisturbID, DisturbID_DLC, 0,levels, 8,1);   //ID  字节长度   从第几位开始  
  if(flag==2)
  {
//    byte0=byte0<<7;
//    write("byte0=====%x",byte0);
//    byte0=byte0^0xFF;
//    write("~byte0=====%x",byte0);
    for(i=0;i<8;i++)
    {
      if((byte0>>i) & 0x1 == 1)
      { 
        write("i=====%d",i);
        break;
      }
      
    }
    //linInvertRespBit (DisturbID, 0,  DisturbID_DLC,byte0,1);    //(Msg.id, 0,  长度,byte0,1)      
    linInvertRespBit (DisturbID, 0,  i, 0 ,1);    //
  }
  if(flag==3)
  linInvertRespBit (DisturbID, DisturbID_DLC-1, 8,0,1);
}
