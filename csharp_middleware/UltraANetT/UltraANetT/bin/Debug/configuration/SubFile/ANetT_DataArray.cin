/*@!Encoding:936*/
void MaxOrMin(int ArraySize,long Data[],int mod,int& WorstNum)//最差值
{
  int i;
  float wrost;
  
  wrost=Data[0];
  WorstNum=0;
  if(mod==0)//最小值
  {
    WorstNum=0;
    for(i=0;i<ArraySize;i++)
    {
     if(wrost>Data[i])
     {
      wrost=Data[i];
      WorstNum=i;
     }
    }
  }
  else if(mod==1)//最大值
  {
    WorstNum=0;
    for(i=0;i<ArraySize;i++)
    {
     if(wrost<Data[i])
     {
      wrost=Data[i];
      WorstNum=i;
     }
    }
  }
}

void ArrayInital(dword array[],int size)

{
  int a;
  a=0;
  do
  {
    array[a]=0;
    a++;
    
  }while(a<size);
}

void ArrayInital(long array[],int size)

{
  int a;
  a=0;
  do
  {
    array[a]=0;
    a++;
    
  }while(a<size);
}

int Search1DArray(dword array[],dword element)
{
  int  i,Nummax,Num,state;
  int Serial; 

  Num=0;
  Nummax=0;
  state=0;
  Serial=0;

  while(1)
  {
    if(state==1)
    break;
    else
    {
      Nummax=Nummax+100;
      for(i=0;i<Nummax;i++)
      {
        if(array[i]==0)
        { Num=i;state=1;break;}
      }
    }
  }
  if(Num==0)
  Serial=-1;
  else
  Serial=999; 
  
  for(i=0;i<Num;i++)
  {
    if(element==array[i])
    { Serial=i;break;}    
  }
  
  return Serial;
}

int AddArray(dword array[],dword element)
{
  int i;
  i=0;
  while(1)
  { 
    if(array[i]==0 || i>5000) break;
    i++;
  }
  array[i]=element;
  i++;
  return i;
}

int AddArray(long array[],long element)
{
  int i;
  i=0;
  while(1)
  {
    if(array[i]==0||i>5000) break;
    i++;
  }
  array[i]=element;
  i++;
  return i;
}

