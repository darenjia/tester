{
  if(Position==1)
  {
//    write("DisturbID111111111=====%x",DisturbID);
//    DisturbID = linGetProtectedID(DisturbID);
//    write("DisturbID222222222=====%x",DisturbID);
//    linSendHeaderError(0x0, DisturbID, 0);
    linInvertHeaderBit(0, 0, 0, 1);        
